AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#source> "ppdb") <http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CHEBI_140503> "ppdb:1306")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#source> "pubmed") <http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CHEBI_140503> "pubmed:32322315")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#source> "reaxys") <http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CHEBI_140503> "reaxys:11323021")
AnnotationAssertion(Annotation(<http://www.geneontology.org/formats/oboInOwl#source> "vsdb") <http://www.geneontology.org/formats/oboInOwl#hasDbXref> <http://purl.obolibrary.org/obo/CHEBI_140503> "vsdb:1306")
