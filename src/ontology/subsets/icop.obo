property_value: terms:created "2025-07-02T19:37:03Z" xsd:dateTime

[Term]
id: OHD:0010261
name: orofacial cluster attacks
def: "Attacks of severe, strictly unilateral facial and/or oral pain, without head pain, lasting 15–180 minutes and occurring from once every other day to eight times a day. The pain is associated with ipsilateral conjunctival injection, lacrimation, nasal congestion, rhinorrhoea, forehead and facial sweating, miosis, ptosis and/or eyelid oedema, and/or with restlessness or agitation." []
comment: ICOP number: 5.3.1
subset: OHD:0010296
is_a: OHD:0010260 ! trigeminal autonomic orofacial pain
