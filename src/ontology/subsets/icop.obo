property_value: terms:created "2025-07-07T17:16:21Z" xsd:dateTime

[Term]
id: OHD:0010262
name: episodic orofacial cluster attacks
def: "Orofacial cluster attacks occurring in periods lasting from 7 days to 1 year, separated by pain-free periods lasting at least 3 months." []
