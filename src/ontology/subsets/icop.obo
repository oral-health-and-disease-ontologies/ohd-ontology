property_value: terms:created "2025-07-02T19:33:53Z" xsd:dateTime

[Term]
id: OHD:0010258
name: chronic orofacial migraine
def: "Facial or oral pain occurring on 15 or more days per month for more than 3 months, which has the features of migraine on at least 8 days per month." []
comment: ICOP number: 5.1.2
subset: OHD:0010296
