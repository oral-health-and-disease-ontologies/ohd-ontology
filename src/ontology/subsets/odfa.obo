[Term]
id: OHD:0000189
name: restored tooth
def: "A tooth that has been restored by using dental restoration material to replace decayed or missing parts of the tooth." []
is_a: UBERON:0001091 {is_inferred="true"} ! calcareous tooth
intersection_of: UBERON:0001091 ! calcareous tooth
intersection_of: has_part OHD:0000000 ! dental restoration material
property_value: IAO:0000116 "Bill Duncan 12/29/2017:\nA restored tooth typically results when a tooth with some type of pathological defect is restored." xsd:string
property_value: IAO:0000116 "Titus Schleyer 1/1/2014: updated definition" xsd:string
property_value: IAO:0000117 "Alan Ruttenberg" xsd:string
property_value: terms:contributor https://orcid.org/0000-0001-9625-1899

[Term]
id: OHD:0000190
