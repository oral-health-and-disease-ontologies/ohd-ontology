[Term]
id: OHD:0000314
name: prosthetic role
def: "A material to be added role that inheres in a material entity that replaces some missing body part." []
is_a: OBI:0000319 ! material to be added role
relationship: BFO:0000052 BFO:0000040 ! inheres in material entity
property_value: IAO:0000112 "A glass eye (see  http://en.wikipedia.org/wiki/Ocular_prosthesis)" xsd:string
property_value: IAO:0000112 "A prothetic hand (see http://bebionic.com)" xsd:string
property_value: IAO:0000116 "Bill Duncan / Alan Ruttenber 12/16/2014:\n\nProsthics may be either functional for non-functional. For example, a glass eye bears a prosthetic role, but it does not see. " xsd:string
property_value: IAO:0000117 "Alan Ruttenberg" xsd:string
property_value: IAO:0000117 "Bill Dunan" xsd:string

[Term]
id: OHD:0000315
