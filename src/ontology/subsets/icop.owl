        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.2.3</rdfs:comment>
        <rdfs:label xml:lang="en">probable persistent idiopathic facial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010284 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010284">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010275"/>
        <obo:IAO_0000115>Persistent unilateral intraoral dentoalveolar pain, rarely occurring in multiple sites, with variable features but recurring daily for more than 2 hours per day for more than 3 months, in the absence of any preceding causative event.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:39:28Z</terms:created>
