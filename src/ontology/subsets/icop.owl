        <owl:versionIRI rdf:resource="http://purl.obolibrary.org/obo/ohd/releases/2026-04-03/icop.owl"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9191-6978"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9990-8331"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-0766-8455"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-3097-4717"/>
        <terms:contributor rdf:resource="https://orcid.org/0000-0002-3943-6819"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-7246-1252"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0008-1739-5105"/>
        <terms:description>The International Classification of Orofacial Pain Ontology (ICOP) contains terms for defining and classifying Orofacial Pain types. The ICOP’s concepts and relations facilitate the development of tools and resources capable of enhancing our understanding of orofacial pain.

The ICOP is developed as a subset of the Oral Health and Disease Ontology (http://purl.obolibrary.org/obo/ohd.owl). Issues and new term requests can be submitted at https://github.com/oral-health-and-disease-ontologies/ohd-ontology/issues.</terms:description>
        <terms:license rdf:resource="http://creativecommons.org/licenses/by/4.0/"/>
        <terms:title>International Classification of Orofacial Pain (ICOP)</terms:title>
        <owl:versionInfo>2026-04-03</owl:versionInfo>
    </owl:Ontology>
    


