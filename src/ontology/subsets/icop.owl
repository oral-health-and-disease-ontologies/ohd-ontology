            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Periodontal pain due to periodontitis as a manifestation of a systematic haematological disorder. Haematological disorders which can result in periodontitis include acquired neutropenia and leukaemia.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
