        <rdfs:label xml:lang="en">neuropathic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010253 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010253">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010132"/>
        <obo:IAO_0000115>Glossopharyngeal nerve associated pain that occurs within the distribution of the glossopharyngeal nerve (posterior part of the tongue, tonsillar fossa, pharynx or beneath the angle of the lower jaw). In addition, pain is commonly perceived in the ipsilateral ear. The primary pain is usually continuous or near-continuous, and commonly described as burning or squeezing, or likened to pins and needles. Brief paroxysms may be superimposed but they are not the predominant pain type. This combination distinguishes 4.2.2 Glossopharyngeal neuropathic pain from 4.2.1 Glossopharyngeal neuralgia. Sensory deficits may be present in the ipsilateral posterior part of the tongue and tonsillar fossa, and the gag reflex may be weak or missing.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:24:40Z</terms:created>
        <oboInOwl:hasRelatedSynonym>glossopharyngeal neuropathic pain due to a known cause</oboInOwl:hasRelatedSynonym>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.2.2</rdfs:comment>
        <rdfs:comment>realted ICOP number: 4.2.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">glossopharyngeal neuropathic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010254 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010254">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010253"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010251"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Unilateral continuous or near-continuous pain, with or without superimposed brief paroxysms, in the distribution(s) of the glossopharyngeal nerve and of unknown aetiology.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:28:43Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.2.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">idiopathic glossopharyngeal neuropathic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010255 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010255">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010000"/>
        <obo:IAO_0000115>Orofacial pains resembling presentations of primary headaches.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:31:48Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5</rdfs:comment>
        <rdfs:label xml:lang="en">orofacial pain with headache presentation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010256 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010256">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010255"/>
        <obo:IAO_0000115>Episodic or chronic pain exclusively in the orofacial region, without head pain, with the characteristics and associated features of 1. Migraine described in ICHD-3.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:32:24Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.1</rdfs:comment>
        <rdfs:label xml:lang="en">orofacial migraine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010257 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010257">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010256"/>
        <obo:IAO_0000115>Recurrent orofacial pain (OFP) attacks, without head pain, lasting 4–72 hours. Typical characteristics of the pain are unilateral location, pulsating quality, moderate or severe intensity, aggravation by routine physical activity and association with nausea and/or photophobia and phonophobia.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:33:53Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">episodic orofacial migraine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010258 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010258">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010256"/>
        <obo:IAO_0000115>Facial or oral pain occurring on 15 or more days per month for more than 3 months, which has the features of migraine on at least 8 days per month.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:34:44Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic orofacial migraine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010259 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010259">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010255"/>
        <obo:IAO_0000115>Episodic or chronic pain exclusively in the orofacial region, without head pain, with the characteristics and associated features of 2. Tension-type headache described in the International Classification of Headache Disorders 3rd Edition, which can include pressing or tightening with mild to moderate intensity with bilateral location.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:36:31Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.2</rdfs:comment>
        <rdfs:label xml:lang="en">tension-type orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010260 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010260">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010255"/>
        <obo:IAO_0000115>Attacks of pain, exclusively in the orofacial region, without head pain, with the characteristics and associated features of a disorder described under 3. Trigeminal autonomic cephalalgias in the International Classification of Headache Disorders 3rd Edition, which include conjunctival injection and/or lacrimation, nasal congestion and/or rhinorrhoea, eyelid oedema, forehead and facial sweating, miosis and/or ptosis.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:37:03Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3</rdfs:comment>
        <rdfs:label xml:lang="en">trigeminal autonomic orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010261 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010261">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010260"/>
        <obo:IAO_0000115>Attacks of severe, strictly unilateral facial and/or oral pain, without head pain, lasting 15–180 minutes and occurring from once every other day to eight times a day. The pain is associated with ipsilateral conjunctival injection, lacrimation, nasal congestion, rhinorrhoea, forehead and facial sweating, miosis, ptosis and/or eyelid oedema, and/or with restlessness or agitation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:16:21Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.1</rdfs:comment>
        <rdfs:label xml:lang="en">orofacial cluster attacks</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010262 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010262">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010261"/>
        <obo:IAO_0000115>Orofacial cluster attacks occurring in periods lasting from 7 days to 1 year, separated by pain-free periods lasting at least 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:16:59Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">episodic orofacial cluster attacks</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010263 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010263">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010261"/>
        <obo:IAO_0000115>Orofacial cluster attacks occurring for more than 1 year without remission, or with remission periods lasting less than 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:17:49Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic orofacial cluster attacks</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010264 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010264">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010260"/>
        <obo:IAO_0000115>Attacks of severe, strictly hemifacial pain, without head pain, lasting 2–30 minutes and occurring several or many times a day. The attacks may be associated with ipsilateral conjunctival injection, lacrimation, nasal congestion, rhinorrhoea, forehead and facial sweating, miosis, ptosis and/or eyelid oedema.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:18:22Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.2</rdfs:comment>
        <rdfs:label xml:lang="en">paroxysmal hemifacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010265 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010265">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010264"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010266"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Attacks of paroxysmal hemifacial pain occurring in periods lasting from 7 days to 1 year, separated by pain-free periods lasting at least 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:19:05Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">episodic paroxysmal hemifacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010266 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010266">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000085"/>
        <obo:IAO_0000115>Pain occuring from 7 days to 1 year, separated by pain-free periods lasting at least 3 months.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:20:14Z</terms:created>
        <rdfs:label xml:lang="en">episodic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010267 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010267">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010264"/>
        <obo:IAO_0000115>Attacks of paroxysmal hemifacial pain occurring for more than 1 year without remission, or with remission periods lasting less than 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:22:04Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic paroxysmal hemifacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010268 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010268">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010260"/>
        <obo:IAO_0000115>Attacks of moderate or severe, strictly unilateral oral and/or facial pain, without head pain, lasting seconds to minutes, occurring at least once a day and usually associated with prominent lacrimation and redness of the ipsilateral eye and/or other local autonomic symptoms and/or signs.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:23:06Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.3</rdfs:comment>
        <rdfs:label xml:lang="en">short-lasting unilateral neuralgiform facial pain attacks with cranial autonomic symptoms (SUNFA)</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010269 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010269">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010268"/>
        <obo:IAO_0000115>Attacks of SUNFA occurring in periods lasting from 7 days to 1 year, separated by pain-free periods lasting at least 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:26:23Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.3.1</rdfs:comment>
        <rdfs:label xml:lang="en">episodic SUNFA</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010270 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010270">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010268"/>
        <obo:IAO_0000115>Attacks of SUNFA occurring for more than 1 year without remission, or with remission periods lasting less than 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:26:56Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.3.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic SUNFA</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010271 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010271">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010260"/>
        <obo:IAO_0000115>While no isolated facial equivalent of 3.4 Hemicrania continua, described in International Classification of Headache Disorders 3rd Edition,, has so far been clearly established, extension of pain into the face in hemicrania continua has been described. Thus, pain referral and/or radiation to oral and/or facial structures may cause diagnostic difficulties.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:27:44Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.4</rdfs:comment>
        <rdfs:label xml:lang="en">hemifacial continuous pain with autonomic symptoms</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010272 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010272">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010255"/>
        <obo:IAO_0000115>Attacks of variable duration of moderate or severe intraoral pain, without head pain, often accompanied by toothache-like symptoms, with mild autonomic and/or migrainous symptoms. Two subforms are represented by patients with relatively short attacks (1–4 hours) and those with longer attacks (&gt;4 hours).</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:28:50Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.4</rdfs:comment>
        <rdfs:label xml:lang="en">neurovascular orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010273 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010273">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010272"/>
        <obo:IAO_0000115>Neurovascular orofacial pain that lasts between 1-4 hours.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:30:01Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.4.1</rdfs:comment>
        <rdfs:label xml:lang="en">short-lasting neurovascular orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010274 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010274">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010272"/>
        <obo:IAO_0000115>Neurovascular orofacial pain that lasts more than 4 hours.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:30:34Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.4.2</rdfs:comment>
        <rdfs:label xml:lang="en">long-lasting neurovascular orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010275 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010275">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010000"/>
        <obo:IAO_0000115>Orofacial pain involving unilateral or bilateral intraoral or facial pain in the distribution(s) of one or more branches of the trigeminal nerve(s) for which the aetiology is unknown. The pain is usually persistent, of moderate intensity, poorly localized and described as dull, pressing or of burning character.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:31:21Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6</rdfs:comment>
        <rdfs:label xml:lang="en">idiopathic orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010276 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010276">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010275"/>
        <obo:IAO_0000115>An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day for more than 3 months, without evident causative lesions on clinical examination and investigation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:32:34Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.1</rdfs:comment>
        <rdfs:label xml:lang="en">burning mouth syndrome (BMS)</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010277 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010277">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010276"/>
        <obo:IAO_0000115>An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day for more than 3 months, unaccompanied by somatosensory changes and without evident causative lesions on clinical examination and investigation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:33:11Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">burning mouth syndrome without somatosensory changes</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010278 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010278">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010276"/>
        <obo:IAO_0000115>An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day for more than 3 months and accompanied by negative and/or positive somatosensory changes, without evident causative lesion(s) on clinical examination and investigation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:34:39Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">burning mouth syndrome with somatosensory changes</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010279 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010279">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010276"/>
        <obo:IAO_0000115>An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day but for less than 3 months, without evident causative lesions on clinical examination and investigation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:35:50Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.1.3</rdfs:comment>
        <rdfs:label xml:lang="en">probable burning mouth syndrome</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010280 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010280">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010275"/>
        <obo:IAO_0000115>Persistent facial pain, with variable features, recurring daily for more than 2 hours per day for more than 3 months, in the absence of clinical neurological deficit or preceding causative event.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:36:33Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.2</rdfs:comment>
        <rdfs:label xml:lang="en">persistent idiopathic facial pain (PIFP)</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010281 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010281">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010280"/>
        <obo:IAO_0000115>Persistent facial pain, with variable features, recurring daily for more than 2 hours per day for more than 3 months, unaccompanied by somatosensory changes and in the absence of clinical neurological deficit or preceding causative event.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:37:25Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">persistent idiopathic facial pain without somatosensory changes</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010282 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010282">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010280"/>
        <obo:IAO_0000115>Persistent facial pain, with variable features, recurring daily for more than 2 hours per day for more than 3 months and accompanied by negative and/or positive somatosensory changes, in the absence of clinical neurological deficit or preceding causative event.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:38:09Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">persistent idiopathic facial pain with somatosensory changes</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010283 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010283">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010280"/>
        <obo:IAO_0000115>Facial pain, with variable features, recurring daily for more than 2 hours per day but for less than 3 months, in the absence of clinical neurological deficit or preceding causative event.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
