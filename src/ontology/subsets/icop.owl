        <obo:RO_0002161 rdf:resource="http://purl.obolibrary.org/obo/NCBITaxon_9761"/>
        <obo:UBPROP_0000003>The ancestor of recent vertebrate teeth was a tooth-like structure on the outer body surface of jawless fishes.[well established][VHOG]</obo:UBPROP_0000003>
        <obo:UBPROP_0000007>dental</obo:UBPROP_0000007>
        <obo:UBPROP_0000008>absent in living platypus, present in toothed Miocene platypus Obduron dicksoni</obo:UBPROP_0000008>
