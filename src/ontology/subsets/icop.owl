    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010128 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010128">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010004"/>
        <obo:IAO_0000115>Pain localized to the temporomandibular joint (TMJ) and caused by another identified disorder, such as inflammation (due, for example, to trauma, infection, crystal deposition or autoimmune disorder), sensitization of the tissues, structural changes (such as osteoarthrosis, disc displacement or subluxation) or injury.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-18T17:46:47Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2</rdfs:comment>
        <rdfs:label xml:lang="en">secondary temporomandibular joint pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010129 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010129">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010059"/>
        <obo:IAO_0000115>Orofacial pain experienced as unilateral brief electric shock-like pains, abrupt in onset and termination, limited to the distribution of one or more divisions of the trigeminal nerve and triggered by innocuous stimuli.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-18T17:50:39Z</terms:created>
        <oboInOwl:hasRelatedSynonym>trigeminal neuralgia</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>trigeminal neuralgia attributed to other cause</oboInOwl:hasRelatedSynonym>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.1.1</rdfs:comment>
        <rdfs:comment>Trigeminal neuralgic pain may develop without apparent cause or be a result of another disorder. Additionally, there may or may not be concomitant continuous pain of moderate intensity within the affected division(s).</rdfs:comment>
        <rdfs:comment>related ICOP number: 4.1.1.2.3</rdfs:comment>
        <rdfs:label xml:lang="en">trigeminal neuralgic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010130 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010130">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010129"/>
        <obo:IAO_0000115>Trigeminal neuralgia developing without apparent cause other than neurovascular compression.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-18T17:51:40Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.1.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">classic trigeminal neuralgia</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010131 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010131">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010129"/>
        <obo:IAO_0000115>Trigeminal neuralgia caused by an underlying disease. Clinical examination shows sensory changes in a substantial percentage of these patients.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-18T17:53:30Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.1.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">secondary trigeminal neuralgia</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010132 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010132">
