        <oboInOwl:hasRelatedSynonym>antimicrobial peptide activity</oboInOwl:hasRelatedSynonym>
        <oboInOwl:hasRelatedSynonym>defense/immunity protein activity</oboInOwl:hasRelatedSynonym>
