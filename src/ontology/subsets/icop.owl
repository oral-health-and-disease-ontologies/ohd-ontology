    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010134">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010133"/>
        <obo:IAO_0000115>Glossopharyngeal neuralgia with recurrent paroxysms of unilateral pain with the demonstration of magnetic resonance imaging.</obo:IAO_0000115>
