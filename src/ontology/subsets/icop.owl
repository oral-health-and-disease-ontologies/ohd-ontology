        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.2.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to disc displacement with reduction, with intermittent locking</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010242 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010242">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010239"/>
        <obo:IAO_0000115>Secondary temporomandibulare join pain due to TMJ disc displacement without reduction, which has been diagnosed by jaw locking or limitation of jaw opening. Along with evidence of pain developing in close temporal relation to the disc dsiplacement, a significant worsening in pain paralelle.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:04:14Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to disc displacement without reduction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010243 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010243">
