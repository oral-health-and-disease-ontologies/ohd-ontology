        <rdfs:label xml:lang="en">idiopathic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010252 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010252">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000085"/>
        <obo:IAO_0000115>Pain cause by damage to nerve fibers.</obo:IAO_0000115>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
