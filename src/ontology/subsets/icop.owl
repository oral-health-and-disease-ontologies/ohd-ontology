        <rdfs:comment>ICOP number: 3.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to disc displacement</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010240 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010240">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010239"/>
        <obo:IAO_0000115>Secondary temporomandibular joint pain due to TMJ disc displacement with reduction that any TMJ noise on jaw movement or function have been reported and clicking, popping, or snapping noises detected with palpation on the jaw opening and closing.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:01:04Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to disc displacement with reduction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010241 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010241">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010240"/>
        <obo:IAO_0000115>Temporomandibular joint pain due to disc displacement with reduction with intermittent jaw locking with limited mouth opening.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
