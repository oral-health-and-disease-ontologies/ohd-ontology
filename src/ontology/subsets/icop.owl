        <rdfs:comment>ICOP number: 2.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">acute primary myofascial orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010217 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010217">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010215"/>
        <obo:IAO_0000115>Mild to moderate levels of deep aching or pressing pain in the masticatory muscles, occurring episodically or unremittingly, often associated with functional impairment such as perceived difficulties in moving the lower jaw, chewing and/or yawning, etc., and with onset more than 3 months ago. It is often associated with psychosocial distress.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-30T18:39:42Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
