    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000179"/>
