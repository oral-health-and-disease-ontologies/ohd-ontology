    <!-- http://purl.obolibrary.org/obo/OHD_0000189 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000189">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UBERON_0001091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000000"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001091"/>
        <obo:IAO_0000115>A tooth that has been restored by using dental restoration material to replace decayed or missing parts of the tooth.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/29/2017:
A restored tooth typically results when a tooth with some type of pathological defect is restored.</obo:IAO_0000116>
        <obo:IAO_0000116>Titus Schleyer 1/1/2014: updated definition</obo:IAO_0000116>
        <obo:IAO_0000117>Alan Ruttenberg</obo:IAO_0000117>
        <terms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <rdfs:label xml:lang="en">restored tooth</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0000189"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001091"/>
        <oboInOwl:is_inferred>true</oboInOwl:is_inferred>
    </owl:Axiom>
    


