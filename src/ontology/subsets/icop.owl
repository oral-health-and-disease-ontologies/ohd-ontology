    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000314 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000314">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000319"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000052"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/BFO_0000040"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>A glass eye (see  http://en.wikipedia.org/wiki/Ocular_prosthesis)</obo:IAO_0000112>
        <obo:IAO_0000112>A prothetic hand (see http://bebionic.com)</obo:IAO_0000112>
        <obo:IAO_0000115>A material to be added role that inheres in a material entity that replaces some missing body part.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan / Alan Ruttenber 12/16/2014:

Prosthics may be either functional for non-functional. For example, a glass eye bears a prosthetic role, but it does not see. </obo:IAO_0000116>
        <obo:IAO_0000117>Alan Ruttenberg</obo:IAO_0000117>
        <obo:IAO_0000117>Bill Dunan</obo:IAO_0000117>
        <rdfs:label>prosthetic role</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000315 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000315">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000314"/>
        <obo:IAO_0000112>A prosthic hand</obo:IAO_0000112>
        <obo:IAO_0000115>A prosthetic role that is realized by activities in which the material entity (bearing the role) is used a manner that is similar to how the body part that the prosthesis replaces would be used.</obo:IAO_0000115>
        <obo:IAO_0000117>Alan Ruttenberg</obo:IAO_0000117>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <rdfs:label>functional prosthetic role</rdfs:label>
    </owl:Class>
    


