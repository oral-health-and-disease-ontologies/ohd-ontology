        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#pheno_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#uberon_slim"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#vertebrate_core"/>
        <rdfs:isDefinedBy rdf:resource="http://purl.obolibrary.org/obo/ohd/imports/uberon_import.owl"/>
        <rdfs:label>muscle organ</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001630"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Organ consisting of a tissue made up of various elongated cells that are specialized to contract and thus to produce movement and mechanical work[GO].</owl:annotatedTarget>
        <oboInOwl:hasDbXref>GO:0007517</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001630"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000001"/>
        <owl:annotatedTarget>Portion of tissue composed of contractile fibers.[TAO]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-08-14</oboInOwl:date_retrieved>
        <oboInOwl:external_class>TAO:0005145</oboInOwl:external_class>
        <oboInOwl:ontology>TAO</oboInOwl:ontology>
        <oboInOwl:source>ZFIN:curator</oboInOwl:source>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001630"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000003"/>
        <owl:annotatedTarget>It seems clear that the metazoan ancestor inherited from its unicellular descendants an actin cytoskeleton and motor-proteins of the myosin superfamily. Within metazoans, these two molecules were arranged into effective contractile units, the muscles. The basic trends for muscle evolution are already expressed in the diploblastic taxa.[well established][VHOG]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-09-17</oboInOwl:date_retrieved>
        <oboInOwl:external_class>VHOG:0001245</oboInOwl:external_class>
        <oboInOwl:ontology>VHOG</oboInOwl:ontology>
        <oboInOwl:source>ISBN:978-0198566694 Schmidt-Rhaesa A, The evolution of organ systems (2007) p.75</oboInOwl:source>
        <oboInOwl:source>http://bgee.unil.ch/</oboInOwl:source>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001630"/>
