        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.2.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">classical glossopharyngeal neuralgia</rdfs:label>
    </owl:Class>
    


