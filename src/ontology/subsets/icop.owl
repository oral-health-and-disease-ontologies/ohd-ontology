    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/BFO_0000002"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000180"/>
        <owl:annotatedTarget>Continuant</owl:annotatedTarget>
        <prov:wasDerivedFrom rdf:resource="http://purl.obolibrary.org/obo/ohd/imports/caro_import.owl"/>
