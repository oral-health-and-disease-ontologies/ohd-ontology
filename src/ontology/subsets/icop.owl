        <rdfs:comment>ICOP number: 4.1.1.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">trigeminal neuralgia due to multiple sclerosis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010247 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010247">
