                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010140"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Mild to moderate levels of deep aching or pressing pain in the masticatory muscles, occurring episodically or unremittingly, often associated with functional impairment such as perceived difficulties in moving the lower jaw, chewing and/or yawning, etc., and with onset within the last 3 months.</obo:IAO_0000115>
