        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000008"/>
        <owl:annotatedTarget>Some synapsids retained two pairs of jaw joints - quadrate-articular and tempero-mandibular, but this unusual paired condition did not last long</owl:annotatedTarget>
        <oboInOwl:source>http://evolution.berkeley.edu</oboInOwl:source>
    </owl:Axiom>
    


