            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010251"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Glossopharyngeal neuralgia with recurrent paroxysms of unilateral pain without neurovascular compression or an underlying disease know to cause secondary glossopharyngeal neuralgia.</obo:IAO_0000115>
