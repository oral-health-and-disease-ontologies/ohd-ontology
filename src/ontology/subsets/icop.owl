        <rdfs:isDefinedBy rdf:resource="http://purl.obolibrary.org/obo/omrse.owl"/>
        <rdfs:isDefinedBy rdf:resource="http://purl.obolibrary.org/obo/ohd/imports/uberon_import.owl"/>
        <rdfs:label xml:lang="en">independent continuant</rdfs:label>
