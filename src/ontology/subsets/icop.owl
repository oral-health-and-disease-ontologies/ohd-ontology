            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Chronic highly frequent primary temporomandibular joint pain on temporomandibular joint palpation beyond the area of the joint.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-18T17:44:03Z</terms:created>
