    <!-- http://purl.obolibrary.org/obo/OHD_0000302 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000302">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000206"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000301"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000053"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000315"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>a prosthesis that has been fabricated for use as a substitute for a natural tooth</obo:IAO_0000115>
        <obo:IAO_0000116>usually made of porcelain or plastic </obo:IAO_0000116>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <obo:IAO_0000119>Mosby. Mosby&apos;s Dental Dictionary, 2nd Edition. Mosby, 2008. VitalBook file. p. 689</obo:IAO_0000119>
        <rdfs:label>prosthetic tooth</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0000302"/>
        <owl:annotatedProperty rdf:resource="http://www.w3.org/2000/01/rdf-schema#subClassOf"/>
        <owl:annotatedTarget rdf:resource="http://purl.obolibrary.org/obo/OHD_0000206"/>
