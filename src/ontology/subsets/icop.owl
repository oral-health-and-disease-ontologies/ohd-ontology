    <!-- http://purl.obolibrary.org/obo/UBERON_0007845 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/UBERON_0007845">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0002384"/>
        <owl:disjointWith rdf:resource="http://purl.obolibrary.org/obo/UBERON_0011821"/>
        <obo:IAO_0000115>Connective tissue, which consists of fibroblasts, the intercellular matrix of which contains a regular network of collagen and elastic fiber bundles. Examples: bone (tissue), cartilage (tissue), dense regular connective tissue.</obo:IAO_0000115>
        <obo:IAO_0000116>the connective tissue hierarchy largely follows FMA with definitions from VSAO. Note that in FMA, loose-CT is irregular-CT. This means regular-CT is necessarily equivalent to dense-regular-CT (assuming a JEPD classification).</obo:IAO_0000116>
        <oboInOwl:hasDbXref>FMA:20103</oboInOwl:hasDbXref>
        <oboInOwl:id>UBERON:0007845</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#human_subset"/>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/uberon/core#mouse_subset"/>
        <rdfs:isDefinedBy rdf:resource="http://purl.obolibrary.org/obo/ohd/imports/uberon_import.owl"/>
        <rdfs:label>regular connective tissue</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0007845"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Connective tissue, which consists of fibroblasts, the intercellular matrix of which contains a regular network of collagen and elastic fiber bundles. Examples: bone (tissue), cartilage (tissue), dense regular connective tissue.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>FMA:20103</oboInOwl:hasDbXref>
    </owl:Axiom>
    


