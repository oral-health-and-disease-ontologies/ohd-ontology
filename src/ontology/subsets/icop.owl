    <!-- http://purl.obolibrary.org/obo/OHD_0010286 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010286">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010284"/>
        <obo:IAO_0000115>Persistent unilateral intraoral dentoalveolar pain, rarely occurring in multiple sites, with variable features, recurring daily for more than 2 hours per day for more than 3 months and accompanied by negative and/or positive somatosensory changes, in the absence of any preceding causative event.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
