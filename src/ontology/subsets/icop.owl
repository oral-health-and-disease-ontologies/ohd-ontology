            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Orofacial pain attributed to lesion or disease of the glossopharyngeal nerve.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-18T17:55:16Z</terms:created>
        <oboInOwl:hasExactSynonym>glossopharyngeal nerve associated pain</oboInOwl:hasExactSynonym>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.2</rdfs:comment>
        <rdfs:label xml:lang="en">pain due to lesion or disease of the glossopharyngeal nerve</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010133 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010133">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010132"/>
        <obo:IAO_0000115>A disorder characterized by unilateral brief stabbing pain, abrupt in onset and termination, in the distributions not only of the glossopharyngeal nerve but also of the auricular and pharyngeal branches of the vagus nerve. Pain is experienced in the ear, base of the tongue, tonsillar fossa and/or beneath the angle of the jaw. It is commonly provoked by swallowing, talking or coughing and may remit and relapse in the fashion of Trigeminal neuralgia.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-18T17:56:55Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">glossopharyngeal neuralgia</rdfs:label>
    </owl:Class>
    


