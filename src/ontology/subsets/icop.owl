    <!-- http://purl.obolibrary.org/obo/OHD_0000051 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000051">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OHD_0000179"/>
