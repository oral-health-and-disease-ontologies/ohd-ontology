    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010244 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010244">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010128"/>
        <obo:IAO_0000115>TMJ pain caused by subluxation, in the absence of TMJ arthritis. It is usually acute, and probably due to overstretching of tissues.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <terms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <terms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:06:56Z</terms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.4</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain due to subluxation</rdfs:label>
    </owl:Class>
    


