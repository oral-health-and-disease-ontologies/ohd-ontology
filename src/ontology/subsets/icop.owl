        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.1.2.3.1</rdfs:comment>
        <rdfs:label xml:lang="en">chronic highly frequent primary temporomandibular joint pain without pain referral</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010127 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010127">
