    <!-- http://purl.obolibrary.org/obo/GO_0006954 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/GO_0006954">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/GO_0006952"/>
        <obo:IAO_0000115>The immediate defensive reaction (by vertebrate tissue) to infection or injury caused by chemical or physical agents. The process is characterized by local vasodilation, extravasation of plasma into intercellular spaces and accumulation of white blood cells and macrophages.</obo:IAO_0000115>
        <oboInOwl:hasBroadSynonym>inflammation</oboInOwl:hasBroadSynonym>
        <oboInOwl:hasDbXref>Wikipedia:Inflammation</oboInOwl:hasDbXref>
        <oboInOwl:hasOBONamespace>biological_process</oboInOwl:hasOBONamespace>
        <oboInOwl:id>GO:0006954</oboInOwl:id>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/go#goslim_generic"/>
        <rdfs:isDefinedBy rdf:resource="http://purl.obolibrary.org/obo/go.owl"/>
        <rdfs:label>inflammatory response</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/GO_0006954"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>The immediate defensive reaction (by vertebrate tissue) to infection or injury caused by chemical or physical agents. The process is characterized by local vasodilation, extravasation of plasma into intercellular spaces and accumulation of white blood cells and macrophages.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>GO_REF:0000022</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ISBN:0198506732</oboInOwl:hasDbXref>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/GO_0006955 -->

