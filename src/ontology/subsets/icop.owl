        <oboInOwl:hasDbXref>VHOG:0001589</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>VSAO:0000069</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>Wikipedia:Dentin</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>XAO:0004051</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>ZFA:0005143</oboInOwl:hasDbXref>
        <oboInOwl:hasExactSynonym>dentin</oboInOwl:hasExactSynonym>
        <oboInOwl:hasExactSynonym>dentine of tooth</oboInOwl:hasExactSynonym>
