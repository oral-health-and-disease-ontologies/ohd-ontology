        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000042"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>Multi-tissue structure that is comprised of a secretory epithelial layer (mesothelium) and a connective tissue layer.</owl:annotatedTarget>
        <oboInOwl:hasDbXref>Wikipedia:Serous_membrane</oboInOwl:hasDbXref>
        <oboInOwl:hasDbXref>https://github.com/obophenotype/uberon/issues/86</oboInOwl:hasDbXref>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/UBERON_0000042"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/UBPROP_0000001"/>
        <owl:annotatedTarget>A multi-tissue structure that is comprised of a secretory epithelial layer and a connective tissue layer.[TAO]</owl:annotatedTarget>
        <oboInOwl:date_retrieved>2012-08-14</oboInOwl:date_retrieved>
