name: billing code D3330: endodontic therapy,  molar (excluding final restoration)
is_a: CDT:1000011 ! billing code for endodontic therapy (including treatment plan, clinical procedures and follow-up care)
property_value: cdt:label "endodontic therapy,  molar (excluding final restoration)" xsd:string
property_value: dc:identifier "D3330" xsd:string

[Term]
id: CDT:0003346
