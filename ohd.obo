[Term]
id: OGMS:0000081
name: pathological derivation
def: "A pathological bodily process in which matter is reorganized in such a way as to give rise to new pathological formations which take the place of entities existing earlier." []
is_a: OGMS:0000061 ! pathological bodily process
property_value: curator_notes "creation date: 2009-07-13T02:17:24Z" xsd:string
