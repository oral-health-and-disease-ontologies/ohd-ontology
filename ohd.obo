is_a: CDT:1000008 ! billing code for inlay/onlay restorations
property_value: cdt:label "inlay/onlay restorations - metallic" xsd:string

[Term]
id: CDT:1000004
name: billing code for fixed partial denture pontics
is_a: CDT:1000005 ! billing code for prosthodontics, fixed
property_value: cdt:label "fixed partial denture pontics" xsd:string

[Term]
id: CDT:1000005
name: billing code for prosthodontics, fixed
is_a: CDT:1000001 ! current dental terminology code
property_value: cdt:label "prosthodontics, fixed" xsd:string
property_value: editor_note "Each retainer and each pontic constitutes a unit in a fixed partial denture.\nLocal anesthesia is usually considered to be part of Fixed Prosthodontic procedures.\nThe term 'fixed partial denture' replaces the words 'bridge' and 'bridgework' throughout this section. \n\n ISBN:1935201387#CDT 2011-2012 Current Dental Terminology, Chapter 1" xsd:string

