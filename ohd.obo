property_value: dcterms:created "2024-08-30T13:47:42Z" xsd:dateTime

[Term]
id: OHD:0001052
name: synthetic glass matrix ceramic dental restoration material
def: "A glass matrix ceramic dental restoration material that contains synthetic materials which varies among manufacturers, but commonly includes silicon dioxide (SiO2), potassium oxide (K2O), sodium oxide (Na2O), and aluminum oxide (Al2O3)." []
is_a: OHD:0001032 ! glass matrix ceramic dental restoration material
relationship: has_part CHEBI:30187 ! aluminium oxide
relationship: has_part CHEBI:30563 ! silicon dioxide
relationship: has_part CHEBI:88321 ! potassium oxide
property_value: dcterms:contributor https://orcid.org/0000-0001-6424-4096
property_value: dcterms:created "2024-08-30T13:47:59Z" xsd:dateTime

[Term]
id: OHD:0001053
name: leucite based synthetic glass matrix ceramic dental restoration material
def: "A synthetic glass matrix ceramic that contains a leucite (K2OAl2O34SiO2) crystalline phase dispersed in a glass matrix." []
is_a: OHD:0001052 ! synthetic glass matrix ceramic dental restoration material
property_value: dcterms:contributor https://orcid.org/0000-0001-6424-4096
property_value: dcterms:created "2024-08-30T13:48:16Z" xsd:dateTime

[Term]
id: OHD:0001054
