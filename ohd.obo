property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000065
name: progressive disease course
def: "A disease course that (a) does not terminate in a return to normal homeostasis and (b) would, absent intervention, involve an increasing deviation from homeostasis." []
