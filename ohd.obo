[Term]
id: OGMS:0000084
name: organism population
def: "An aggregate of organisms of the same type." []
is_a: BFO:0000040 ! material entity
property_value: curator_notes "creation date: 2009-11-24T04:51:11Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
