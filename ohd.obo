[Term]
id: OGMS:0000085
name: pain
def: "A bodily process in an organism S involving two integrated levels: (a) activation of the nociceptive system and associated emotion generating brain components of S, and (b) a simultaneous aversive sensory and emotional experience on the part of S, where (b) is phenomenologically similar to the sort of aversive experience involved in pain with concordant tissue damage." []
is_a: OGMS:0000020 ! symptom
property_value: curator_notes "creation date: 2009-11-24T04:51:11Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://www.referent-tracking.com/RTU/sendfile/?file=painTokyo1_27_2011.pdf" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000086
name: syndrome
def: "A pattern of signs and symptoms that typically co-occur." []
is_a: BFO:0000019 ! quality
property_value: curator_notes "creation date: 2009-11-24T04:51:11Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/issues/detail?id=32" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000087
name: extended organism
def: "An object aggregate consisting of an organism and all material entities located within the organism, overlapping the organism, or occupying sites formed in part by the organism." []
is_a: BFO:0000040 ! material entity
property_value: curator_notes "creation date: 2010-01-25T04:51:11Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/issues/detail?id=3" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000088
name: patient symptom report
def: "A communication from a patient about something they perceive as being abnormal about their body or life." []
is_a: IAO:0000030 ! information content entity
property_value: curator_notes "creation date: 2010-01-25T04:51:11Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/issues/detail?id=12" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000089
name: congenital disorder
def: "A structurally anomalous part of an organism acquired during fetal development and present at birth (but not necessarily hereditary) which is hypothesized to be harmful for the organism." []
is_a: BFO:0000040 ! material entity
property_value: curator_notes "creation date: 2010-03-31T04:51:11Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000118 "congenital malformation" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/issues/detail?id=28" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000090
name: treatment
def: "A planned process whose completion is hypothesized by a health care provider to eliminate, prevent, or alleviate a disorder, the signs and symptoms of a disorder, or a pathological process" []
is_a: OGMS:0000096 ! health care process
property_value: curator_notes "creation date: 2010-03-31T04:51:11Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/issues/detail?id=35" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000091
name: convalescence
def: "A processual entity during which a patient participating in a disease course gradually returns to participating in a canonical life course." []
is_a: BFO:0000015 ! process
property_value: curator_notes "creation date: 2010-03-31T04:51:11Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/issues/detail?id=35" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000092
name: life course
def: "A process which has as parts all the processes in which a given organism is participant." []
is_a: BFO:0000015 ! process
property_value: curator_notes "creation date: 2010-03-31T04:51:11Z\n\nEDIT: 10 NOV 2015" xsd:string
property_value: IAO:0000117 "Albert Goldfain\nRichard Scheuermann\nSagar Jain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/issues/detail?id=38" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000093
name: prognosis
def: "A hypothesis about some future part of a disease course." []
is_a: IAO:0000027 ! data item
property_value: curator_notes "creation date: 2010-03-31T12:42:23Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/issues/detail?id=35" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000094
name: acute disease course
def: "A disease course with an acute onset" []
is_a: OGMS:0000063 ! disease course
property_value: curator_notes "creation date: 2010-07-19T11:57:44Z\n\n10212020\n\nfor definition use\n\nhttp://purl.obolibrary.org/obo/PATO_0000389" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/wiki/Meeting_notes_20100513" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000095
name: inflammatory process
def: "A bodily process caused by some disorder that results in recruitment of leukocytes into a localized tissue site, typically causing localized pain and swelling." []
is_a: OGMS:0000060 ! bodily process
property_value: curator_notes "creation date: 2010-07-19T11:57:44Z\n\nUpdated: 10 NOV 2015" xsd:string
property_value: IAO:0000117 "Albert Goldfain\nRichard Scheuermann\nSagar Jain" xsd:string
property_value: IAO:0000119 "http://code.google.com/p/ogms/wiki/Meeting_notes_20100513" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000096
name: health care process
def: "A planned process with the objective to improve the health status of a patient that directly involves the treatment, diagnosis, or prevention of disease or injury of a patient" []
is_a: OBI:0000011 ! planned process
property_value: curator_notes "creation date: 2011-02-21T09:57:44Z\neditor date: 2017-04-18" xsd:string
property_value: IAO:0000117 "Albert Goldfain\nSagar Jain" xsd:string
property_value: IAO:0000119 "http://groups.google.com/group/ogms-discuss/browse_thread/thread/a2dbc2ed1dff99d6" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000097
name: health care encounter
def: "A temporally-connected health care process that has as participants an organization or person realizing the health care provider role and a person realizing the patient role.  The health care provider role and patient are realized during the health care encounter" []
is_a: OGMS:0000096 ! health care process
property_value: curator_notes "creation date: 2011-02-21T09:57:44Z" xsd:string
property_value: IAO:0000117 "Albert Goldfain" xsd:string
property_value: IAO:0000119 "http://groups.google.com/group/ogms-discuss/browse_thread/thread/a2dbc2ed1dff99d6" xsd:string
property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

