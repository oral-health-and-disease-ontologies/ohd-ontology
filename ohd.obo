property_value: IAO:0000118 "glass polyalkenoate cement" xsd:string
property_value: IAO:0000119 "doi:10.3390/jfb7030016" xsd:string

[Term]
id: OHD:0001007
name: zinc oxide eugenol cement dental restoration material
def: "A zinc-oxide cement dental restoration material containing eugenol as a liquid component to complete the acid-base reaction." []
is_a: OHD:0001022 ! zinc oxide cement dental restoration material
relationship: has_part CHEBI:4917 ! eugenol
property_value: dcterms:contributor https://orcid.org/0000-0001-6424-4096
