property_value: IAO:0000602 "(forall (x) (if (Site x) (ImmaterialEntity x))) // axiom label in BFO2 CLIF: [034-002] " xsd:string {IAO:0010000="http://purl.obolibrary.org/obo/bfo/axiom/034-002"}
