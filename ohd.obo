property_value: isDefinedBy http://purl.obolibrary.org/obo/ro.owl
property_value: RO:0001900 RO:0001901
property_value: seeAlso http://purl.obolibrary.org/obo/ro/docs/reflexivity/
is_a: RO:0002502 ! depends on

