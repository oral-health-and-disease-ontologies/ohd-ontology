property_value: isDefinedBy http://purl.obolibrary.org/obo/ogms.owl

[Term]
id: OGMS:0000055
name: clinical history taking
def: "A health care process in which a clinician elicits a description of previous sign and symptoms of disease from a patient or from a third party who is reporting on behalf of the patient." []
