property_value: IAO:0000119 "PMID:32103673" xsd:string

[Term]
id: OHD:0010217
name: chronic primary myofascial orofacial pain
def: "Mild to moderate levels of deep aching or pressing pain in the masticatory muscles, occurring episodically or unremittingly, often associated with functional impairment such as perceived difficulties in moving the lower jaw, chewing and/or yawning, etc., and with onset more than 3 months ago. It is often associated with psychosocial distress." []
comment: ICOP number: 2.1.2
subset: OHD:0010296
