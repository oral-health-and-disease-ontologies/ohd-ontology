is_a: OHD:0000250 ! removable partial denture procedure
property_value: dcterms:contributor https://orcid.org/0000-0001-9625-1899
creation_date: 2022-12-06T04:15:07Z

[Term]
id: OHD:0000293
name: interim dental implant body
def: "A dental implant body that is placed in the mouth for short duration of time in order to allow adequate time for healing or completion of definitive treatment planning." []
is_a: OHD:0000278 ! dental implant body
property_value: dcterms:contributor https://orcid.org/0000-0001-9625-1899
creation_date: 2022-12-06T04:24:01Z

