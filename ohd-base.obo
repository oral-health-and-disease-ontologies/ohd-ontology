property_value: dcterms:created "2023-06-06T21:30:59Z" xsd:string
property_value: IAO:0000116 "Tooth abfractions are usually wedge-shaped lesions with sharp-line angles, but sometimes circular invaginations on occlusal surfaces." xsd:string
