intersection_of: OBI:0000047
intersection_of: BFO:0000053 OHD:0000314 ! prosthetic role
relationship: BFO:0000053 OHD:0000314 ! prosthetic role
property_value: IAO:0000117 "Bill Duncan" xsd:string

[Term]
id: OHD:0000302
name: prosthetic tooth
def: "a prosthesis that has been fabricated for use as a substitute for a natural tooth" []
is_a: OHD:0000206 ! functional tooth
is_a: OHD:0000301 ! prosthesis
relationship: BFO:0000053 OHD:0000315 ! functional prosthetic role
property_value: IAO:0000116 "usually made of porcelain or plastic " xsd:string
property_value: IAO:0000117 "Bill Duncan" xsd:string
property_value: IAO:0000119 "Mosby. Mosby's Dental Dictionary, 2nd Edition. Mosby, 2008. VitalBook file. p. 689" xsd:string

[Term]
id: OHD:0000303
name: direct restoration procedure
def: "A tooth restoration procedure in which the dental restoration material is placed in the tooth via some direct dental restoration material combination process." []
is_a: OHD:0000004 ! tooth restoration procedure
intersection_of: OHD:0000004 ! tooth restoration procedure
intersection_of: BFO:0000051 OHD:0000037 ! direct dental material insertion process
relationship: BFO:0000051 OHD:0000037 ! direct dental material insertion process
property_value: dcterms:contributor https://orcid.org/0000-0001-9625-1899

[Term]
id: OHD:0000304
name: indirect restoration procedure
def: "A tooth restoration procedure in which the dental restoration material is placed in the tooth via some dental material tooth attachment process." []
is_a: OHD:0000004 ! tooth restoration procedure
intersection_of: OHD:0000004 ! tooth restoration procedure
intersection_of: BFO:0000051 OHD:0000038 ! dental material tooth attachment process
relationship: BFO:0000051 OHD:0000038 ! dental material tooth attachment process
property_value: dcterms:contributor https://orcid.org/0000-0001-9625-1899

[Term]
id: OHD:0000305
name: 3/4 crown restoration procedure
def: "A crown restoration procedure in which 3 of the 4 surfaces on an anterior tooth is restored. The dental restoration material extends to (or almost to) the gum line." []
is_a: OHD:0000033 ! crown restoration procedure
relationship: OBI:0000293 OHD:0000307 ! Anterior Tooth
property_value: dcterms:contributor https://orcid.org/0000-0001-9625-1899

[Term]
id: OHD:0000306
name: dental material fusion process
def: "A dental material combination process in which one or more materials forms a substructure and then one or more materials are fused (or baked) onto this substructure." []
is_a: OHD:0000349 ! dental material combination process
property_value: IAO:0000117 "Bill Duncan" xsd:string

[Term]
id: OHD:0000307
name: Anterior Tooth
def: "A tooth that is either an incisor or a canine." []
is_a: UBERON:0001091
union_of: UBERON:0001098
union_of: UBERON:0003674
property_value: IAO:0000117 "Bill Duncan" xsd:string

[Term]
id: OHD:0000308
name: Posterior Tooth
def: "A tooth that is either a molar or premolar." []
is_a: UBERON:0013164
union_of: UBERON:0003655
union_of: UBERON:0007120
property_value: IAO:0000117 "Bill Duncan" xsd:string

[Term]
id: OHD:0000309
name: dental implant retainer attachement procedure for ceramic fixed partial denture
def: "A dental implant retainer attachement procedure for fixed partial denture in which the retainer being attached to the implant body is to be used as a retainer for a ceramic fixed partial denture." []
is_a: OHD:0000300 ! dental implant retainer attachement procedure for fixed partial denture
property_value: dcterms:contributor https://orcid.org/0000-0001-9625-1899
creation_date: 2022-12-06T04:41:10Z

[Term]
id: OHD:0000310
name: partial denture
def: "a prosthesis that replaces one or more, but less than all, of the natural teeth and associated structures " []
is_a: OHD:0000301 ! prosthesis
relationship: BFO:0000051 OHD:0000302 ! prosthetic tooth
property_value: IAO:0000111 "partial denture" xsd:string
property_value: IAO:0000117 "Bill Duncan" xsd:string
property_value: IAO:0000118 "partial dental prothesis" xsd:string
property_value: IAO:0000119 "Mosby. Mosby's Dental Dictionary, 2nd Edition. Mosby, 2008. VitalBook file. p. 175" xsd:string

[Term]
id: OHD:0000311
name: tooth-supported partial denture
def: "A fixed partial denture that is suppored and retained by underlying tissue and some or all of the remaining teeth." []
is_a: OHD:0000312 ! fixed partial denture
property_value: IAO:0000116 "Dan Caplan 12/13/2014:\nMosby's definition is not quite corrrect. The support could also include other teeth that are not adjacent to the endentulous area. The important point is that the prosthesis is supported by existing teeth (wherever they are in the arch), and not by the gingiva.\n" xsd:string
property_value: IAO:0000117 "Bill Duncan" xsd:string
property_value: IAO:0000119 "Mosby. Mosby's Dental Dictionary, 2nd Edition. Mosby, 2008. VitalBook file. p. 175-176" xsd:string

[Term]
id: OHD:0000312
name: fixed partial denture
def: "A partial denture that is permanently attached to prepared natural teeth, roots, or implants." []
is_a: OHD:0000310 ! partial denture
property_value: IAO:0000118 "bridge" xsd:string
property_value: IAO:0000119 "Mosby. Mosby's Dental Dictionary, 2nd Edition. Mosby, 2008. VitalBook file. p. 175" xsd:string

[Term]
id: OHD:0000313
name: fixed partial denture restoration procedure
def: "A tooth restoration procedure in which a fixed partial denture (i.e., bridge) is attached to the supporting teeth." []
is_a: OHD:0000004 ! tooth restoration procedure
property_value: dcterms:contributor https://orcid.org/0000-0001-9625-1899
property_value: IAO:0000118 "A tooth restoration procedure in which a fixed partial denture (i.e., bridge) is attached to the supporting teeth." xsd:string
property_value: IAO:0000118 "bridge restoration procedure" xsd:string

[Term]
id: OHD:0000314
name: prosthetic role
def: "A material to be added role that inheres in a material entity that replaces some missing body part." []
is_a: OBI:0000319
relationship: BFO:0000052 BFO:0000040
property_value: IAO:0000112 "A glass eye (see  http://en.wikipedia.org/wiki/Ocular_prosthesis)" xsd:string
property_value: IAO:0000112 "A prothetic hand (see http://bebionic.com)" xsd:string
property_value: IAO:0000116 "Bill Duncan / Alan Ruttenber 12/16/2014:\n\nProsthics may be either functional for non-functional. For example, a glass eye bears a prosthetic role, but it does not see. " xsd:string
property_value: IAO:0000117 "Alan Ruttenberg" xsd:string
property_value: IAO:0000117 "Bill Dunan" xsd:string

[Term]
id: OHD:0000315
name: functional prosthetic role
def: "A prosthetic role that is realized by activities in which the material entity (bearing the role) is used a manner that is similar to how the body part that the prosthesis replaces would be used." []
is_a: OHD:0000314 ! prosthetic role
property_value: IAO:0000112 "A prosthic hand" xsd:string
property_value: IAO:0000117 "Alan Ruttenberg" xsd:string
property_value: IAO:0000117 "Bill Duncan" xsd:string

