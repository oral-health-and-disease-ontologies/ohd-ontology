property_value: IAO:0000119 "PMID:32103673" xsd:string

[Term]
id: OHD:0010277
name: burning mouth syndrome without somatosensory changes
def: "An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day for more than 3 months, unaccompanied by somatosensory changes and without evident causative lesions on clinical examination and investigation." []
comment: ICOP number: 6.1.1
subset: OHD:0010296
