[Term]
id: OHD:0000221
name: dental procedure finding
def: "A dental finding that a dental procedure has been performed on a patient's mouth." []
is_a: OHD:0000010 ! dental finding
property_value: dcterms:contributor https://orcid.org/0000-0001-9625-1899
property_value: IAO:0000116 "Bill Duncan 12/27/2016:\n\nThis finding can indicate that a procedure was performed even when the output is not observable. For example, by looking a dental record, a provider may find that the last time a patient's teeth were cleaned was two years ago." xsd:string
creation_date: 2016-12-27T01:45:45Z

