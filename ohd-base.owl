                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000190"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A Homo sapiens that bears some dental patient role.</obo:IAO_0000115>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <rdfs:label xml:lang="en">human dental patient</rdfs:label>
