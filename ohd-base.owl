                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000302"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000111>partial denture</obo:IAO_0000111>
        <obo:IAO_0000115>a prosthesis that replaces one or more, but less than all, of the natural teeth and associated structures </obo:IAO_0000115>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <obo:IAO_0000118>partial dental prothesis</obo:IAO_0000118>
        <obo:IAO_0000119>Mosby. Mosby&apos;s Dental Dictionary, 2nd Edition. Mosby, 2008. VitalBook file. p. 175</obo:IAO_0000119>
        <rdfs:label>partial denture</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000311 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000311">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000312"/>
        <obo:IAO_0000115>A fixed partial denture that is suppored and retained by underlying tissue and some or all of the remaining teeth.</obo:IAO_0000115>
        <obo:IAO_0000116>Dan Caplan 12/13/2014:
Mosby&apos;s definition is not quite corrrect. The support could also include other teeth that are not adjacent to the endentulous area. The important point is that the prosthesis is supported by existing teeth (wherever they are in the arch), and not by the gingiva.
</obo:IAO_0000116>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <obo:IAO_0000119>Mosby. Mosby&apos;s Dental Dictionary, 2nd Edition. Mosby, 2008. VitalBook file. p. 175-176</obo:IAO_0000119>
        <rdfs:label>tooth-supported partial denture</rdfs:label>
    </owl:Class>
    


