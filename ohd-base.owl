        <obo:IAO_0000115>An acid-base cement dental restoration material containing basic ion-leachable glass (fluoroaluminosilicate glass) as a powder component with polymeric water-soluble acid (polyacrylic acid, polyprotic carboxylic acid) as liquid component to complete the acid-base reaction.</obo:IAO_0000115>
        <obo:IAO_0000118 xml:lang="en">Glass Ionomer Cement (GIC)</obo:IAO_0000118>
        <obo:IAO_0000118 xml:lang="en">glass polyalkenoate cement</obo:IAO_0000118>
        <obo:IAO_0000119>doi:10.3390/jfb7030016</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-19T15:23:33Z</dcterms:created>
        <rdfs:label>glass ionomer cement dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001007 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001007">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001022"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_4917"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A zinc-oxide cement dental restoration material containing eugenol as a liquid component to complete the acid-base reaction.</obo:IAO_0000115>
        <obo:IAO_0000119>ISBN:0323478212</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-21T13:58:36Z</dcterms:created>
        <rdfs:label>zinc oxide eugenol cement dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001008 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001008">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000000"/>
        <obo:IAO_0000115>A dental restoration material containing calcium aluminate, polyacrylic acid  with basic ion-leachable glass particles as powder component with water as liquid component to complete the acid-base reaction of glass ionomer and hydration of calcium aluminate cement.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-02-08T11:22:23Z</dcterms:created>
        <rdfs:label>calcium aluminate glass ionomer hybrid cement dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001010 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001010">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001022"/>
        <obo:IAO_0000115>A zinc-oxide cement dental restoration material containing aliphatic acid or butyric acid to substitute the eugenol as a liquid component to complete the acid-base reaction.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T12:05:19Z</dcterms:created>
        <rdfs:label>zinc oxide non-eugenol cement dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001010"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A zinc-oxide cement dental restoration material containing aliphatic acid or butyric acid to substitute the eugenol as a liquid component to complete the acid-base reaction.</owl:annotatedTarget>
        <obo:IAO_0000119>ISBN:0323478212</obo:IAO_0000119>
        <obo:IAO_0000119>https://www.ncbi.nlm.nih.gov/pmc/articles/PMC9689175/</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001011 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001011">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000036"/>
        <obo:IAO_0000115>A resin-based composite dental restoration material that enables the restoration to be built up in thick layers of up to 4 mm and are recommended by manufacturers to simplify clinical technique and save time compared to traditional incremental placement.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T12:07:09Z</dcterms:created>
        <rdfs:label>bulk-filled resin-based composite dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001011"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A resin-based composite dental restoration material that enables the restoration to be built up in thick layers of up to 4 mm and are recommended by manufacturers to simplify clinical technique and save time compared to traditional incremental placement.</owl:annotatedTarget>
        <obo:IAO_0000119>Craig&apos;s restorative Dental Material</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001012 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001012">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000036"/>
        <obo:IAO_0000115>A resin-based composite dental restoration material that has low-viscosity and is recommended for cervical lesions, restorations in deciduous teeth, and other small, low- or non-stress bearing restorations.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T12:07:24Z</dcterms:created>
        <rdfs:label>flowable resin-based composite dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001012"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A resin-based composite dental restoration material that has low-viscosity and is recommended for cervical lesions, restorations in deciduous teeth, and other small, low- or non-stress bearing restorations.</owl:annotatedTarget>
        <obo:IAO_0000119>Craig&apos;s restorative Dental Material</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001014 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001014">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000036"/>
        <obo:IAO_0000115>A resin-based composite dental restoration material that contains macrosize filler particles.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T12:08:04Z</dcterms:created>
        <rdfs:label>macrofilled resin-based composite dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001014"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A resin-based composite dental restoration material that contains macrosize filler particles.</owl:annotatedTarget>
        <obo:IAO_0000119>Craig&apos;s restorative Dental Material</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001015 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001015">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000036"/>
        <obo:IAO_0000115>A resin-based composite dental restoration material which is composed of dimethacrylate resins with 0.04-m colloidal silica fillers and prepolymerized resins, which are sometimes filled with colloidal silica.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T12:08:13Z</dcterms:created>
        <rdfs:label>microfilled resin-based composite dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001015"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A resin-based composite dental restoration material which is composed of dimethacrylate resins with 0.04-m colloidal silica fillers and prepolymerized resins, which are sometimes filled with colloidal silica.</owl:annotatedTarget>
        <obo:IAO_0000119>Craig&apos;s restorative Dental Material</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001017 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001017">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000036"/>
        <obo:IAO_0000115>A resin-based composite dental restoration material that contains nanometer-sized filler particles (1 to 100 nm) throughout the resin matrix.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T12:08:41Z</dcterms:created>
        <rdfs:label>nano filled resin-based composite dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001017"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A resin-based composite dental restoration material that contains nanometer-sized filler particles (1 to 100 nm) throughout the resin matrix.</owl:annotatedTarget>
        <obo:IAO_0000119>Craig&apos;s restorative Dental Material</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001018 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001018">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000036"/>
        <obo:IAO_0000115>A resin-based composite dental restoration material which consist of large particles 
(0.4 to 5 m) with added nanometer-sized filler particles. Thus they are hybrid materials, not true nanofilled composites.</obo:IAO_0000115>
        <obo:IAO_0000119 xml:lang="en">Craig&apos;s restorative Dental Material</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T12:08:57Z</dcterms:created>
        <rdfs:label>nano hybrid resin-based composite dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001018"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A resin-based composite dental restoration material which consist of large particles 
(0.4 to 5 m) with added nanometer-sized filler particles. Thus they are hybrid materials, not true nanofilled composites.</owl:annotatedTarget>
        <obo:IAO_0000119>Craig&apos;s restorative Dental Material</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001019 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001019">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000036"/>
        <obo:IAO_0000115>A resin-based composite dental restoration material that contains fluoride-releasing silicate glass filler phase and a methacrylate based matrix with carboxylic acid functional groups.</obo:IAO_0000115>
        <obo:IAO_0000118>polyacid-modified glass ionomer cement</obo:IAO_0000118>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T12:09:12Z</dcterms:created>
        <oboInOwl:hasDbXref>ISBN: 978-81-312-3488-4</oboInOwl:hasDbXref>
        <rdfs:label>compomer resin-based composite dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001019"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A resin-based composite dental restoration material that contains fluoride-releasing silicate glass filler phase and a methacrylate based matrix with carboxylic acid functional groups.</owl:annotatedTarget>
        <obo:IAO_0000119>Craig&apos;s restorative Dental Material</obo:IAO_0000119>
        <obo:IAO_0000119>ISBN: 978-1-4377-2418-9</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001020 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001020">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001021"/>
        <obo:IAO_0000115>An acid-base cement dental restoration material where in  glass ionomer cements  the glasses are fused with metals such as gold, silver, titanium, and silver to improve their strength.</obo:IAO_0000115>
        <obo:IAO_0000118 xml:lang="en">cermet dental restoration material</obo:IAO_0000118>
        <obo:IAO_0000119 xml:lang="en">ISBN:0323478212</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-07-31T15:40:29Z</dcterms:created>
        <rdfs:label>metal modified glass ionomer dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001021 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001021">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000000"/>
        <obo:IAO_0000115>A dental restoration material containing acid and liquid components in powder liquid form.</obo:IAO_0000115>
        <obo:IAO_0000119>ISBN:0323478212</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <rdfs:label>acid-base cement dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001022 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001022">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001021"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_36560"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An acid-base cement dental restoration material containing zinc-oxide as a powder component with some specific liquid component to complete the acid-base reaction.</obo:IAO_0000115>
        <obo:IAO_0000119>ISBN:0323478212</obo:IAO_0000119>
        <obo:IAO_0000119>https://www.iso.org/standard/84407.html</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-08-05T15:44:55Z</dcterms:created>
        <rdfs:label>zinc oxide cement dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001026 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001026">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001021"/>
        <obo:IAO_0000115>An acid-base cement dental restoration material with modification of  glass ionomer cement with some monomer component and associated activator initiator system to facilitate light and chemically activated polymerization reaction.</obo:IAO_0000115>
        <obo:IAO_0000119>doi: 10.3390/jfb7030016</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-08-08T12:27:23Z</dcterms:created>
        <rdfs:comment>The monomer is typically 2-hydroxyethyl methacrylate, HEMA, and the initiator is camphorquinone. Resin-modified glass-ionomers set by the twin processes of neutralization (acid-base reaction) and addition polymerization, and the resulting material has a complicated structure based on the combined products of these two reactions.</rdfs:comment>
        <rdfs:label>resin-modified glass ionomer dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001032 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001032">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000135"/>
        <obo:IAO_0000115>A ceramic dental restoration material that contains crystallized ceramic portions which are uniformally distributed within a glass phase.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:39:47Z</dcterms:created>
        <rdfs:label xml:lang="en">glass matrix ceramic dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001032"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A ceramic dental restoration material that contains crystallized ceramic portions which are uniformally distributed within a glass phase.</owl:annotatedTarget>
        <obo:IAO_0000119>https://doi.org/10.3390/ma16247541</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001033 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001033">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000135"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0001079"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A ceramic dental restoration material that contains small crystals, also known as grains, that are separated by grain boundaries and present a random crystallographic orientation , that do not contain a glass phase.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:41:52Z</dcterms:created>
        <rdfs:label xml:lang="en">polycrystalline ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001034 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001034">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001033"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0001080"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A polycrystalline ceramic dental restoration material that contains Zirconia which is partially stabilized zirconium oxide usually in the tetragonal phase.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:42:45Z</dcterms:created>
        <rdfs:label xml:lang="en">zirconia polycrystalline ceramic dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001034"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A polycrystalline ceramic dental restoration material that contains Zirconia which is partially stabilized zirconium oxide usually in the tetragonal phase.</owl:annotatedTarget>
        <obo:IAO_0000119>ISBN: 9780323697552</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001035 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001035">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001034"/>
        <obo:IAO_0000115>A zirconia polycrystalline ceramic dental restoration material that contains the first generation of dental zirconia fully stabilized with yttria (Y2O3) which are chiefly composed of the tetragonal phase (tetragonal zirconia polycrystals : TZPs) and are stabilized at room temperature with the addition of 3 mol% of yttrium oxide (3Y-TZP).</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:43:04Z</dcterms:created>
        <rdfs:label xml:lang="en">3Y-TZP zirconia ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001036 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001036">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001034"/>
        <obo:IAO_0000115>A zirconia polycrystalline ceramic dental restoration material that contains the next generation of dental zirconia with the addition of transparent, non-birefringent, cubic-phase stabilized with higher yttrium oxide (of approximately 25% of the cubic phase achieved with 4 mol% of yttrium oxide) with increased translucency in relation to 3Y-TZP for monolithic applications.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:43:16Z</dcterms:created>
        <rdfs:label xml:lang="en">4Y-PSZ zirconia ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001037 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001037">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001034"/>
        <obo:IAO_0000115>A zirconia polycrystalline ceramic dental restoration material that contains zirconia with increased yttrium oxide (5-8% mol)</obo:IAO_0000115>
        <obo:IAO_0000118>ultra translucent zironia</obo:IAO_0000118>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:43:35Z</dcterms:created>
        <rdfs:label xml:lang="en">5Y-PSZ zirconia ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001038 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001038">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001034"/>
        <obo:IAO_0000115>A zirconia polycrystalline ceramic dental restoration material that contains additions of layers of different pigments to provide a graded shade between the cervical and the incisal portion of the restoration to mimic the natural tooth appearance.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:43:50Z</dcterms:created>
        <rdfs:label xml:lang="en">multichromatic zirconia ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001039 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001039">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001034"/>
        <obo:IAO_0000115>A zirconia polycrystalline ceramic dental restoration material that contains layered structure composed of different compositions of dental zirconias to provide graded structures that mimic not only the shade, but the translucency and esthetic appearance of natural teeth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:44:12Z</dcterms:created>
        <rdfs:label xml:lang="en">multilayered zirconia ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001040 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001040">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001033"/>
        <obo:IAO_0000115>A polycrystalline ceramic dental restoration material that combines different cryatalline phases to improve specific properties.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:44:39Z</dcterms:created>
        <rdfs:label xml:lang="en">polycrystalline composite ceramic dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0001040"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A polycrystalline ceramic dental restoration material that combines different cryatalline phases to improve specific properties.</owl:annotatedTarget>
        <obo:IAO_0000119>doi: 10.3390/ma16247541</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001041 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001041">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001040"/>
        <obo:IAO_0000115>A polycrystalline composite ceramic dental restoration material that combines zirconium to increase the material&apos;s mechanical and esthetic properties.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:44:55Z</dcterms:created>
        <rdfs:label xml:lang="en">zirconia toughened alumina ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001042 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001042">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001021"/>
        <obo:IAO_0000115>An acid-base cement dental restoration material containing zinc-oxide and magnesium oxide as a powder component with phosphoric acid as liquid component to complete the acid-base reaction.</obo:IAO_0000115>
        <obo:IAO_0000119>ISBN:0323478212</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-09-14T16:34:50Z</dcterms:created>
        <rdfs:label>zinc phosphate cement dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001043 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001043">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001021"/>
        <obo:IAO_0000115>An acid-base cement dental restoration material containing zinc-oxide and magnesium oxide as a powder component with polyacrylic acid and water as liquid component to complete the acid-base reaction.</obo:IAO_0000115>
        <obo:IAO_0000119>ISBN:0323478212</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-09-14T16:35:15Z</dcterms:created>
        <rdfs:label>zinc polycarboxylate cement dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001044 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001044">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000191"/>
        <obo:IAO_0000115>A dental restoration material role that is borne by a portion of dental restoration material in association with bulk restoration and is realized in a tooth restoration procedure in which the restoration material becomes part of a restored tooth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-10-12T11:44:24Z</dcterms:created>
        <rdfs:label>dental prosthesis support role</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001045 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001045">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000000"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_31341"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A dental restoration material that contains calcium hydroxide as a chief ingredient and is suspended in a solvent carrier with a thickening agent.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2023-10-12T12:11:12Z</dcterms:created>
        <rdfs:label>calcium hydroxide cement dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001046 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001046">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001040"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30187"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A polycrystalline composite ceramic dental restoration material that combine alumina to increase materials strength and toughness.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:45:12Z</dcterms:created>
        <rdfs:label xml:lang="en">alumina toughened zirconia ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001047 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001047">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000135"/>
        <obo:IAO_0000115>A ceramic dental restoration material that consists of a ceramic network infiltrated with a polymer resin to integrate the mechanical properties of ceramics with the improved elasticity of resins.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:45:40Z</dcterms:created>
        <rdfs:label xml:lang="en">resin matrix ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001048 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001048">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001047"/>
        <obo:IAO_0000115>A resin matrix ceramic dental restoration material that contains nano ceramic filler, typically to improve esthetics, strength, and wear resistance.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:46:29Z</dcterms:created>
        <rdfs:label xml:lang="en">resin nano ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001049 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001049">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001047"/>
        <obo:IAO_0000115>A resin matrix ceramic dental restoration material that contains either lithium disilicate or leucite-reinforced glass ceramic filler, typically to improve esthetics, strength, and wear resistance.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:46:51Z</dcterms:created>
        <rdfs:label xml:lang="en">resin matrix glass ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001050 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001050">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001047"/>
        <obo:IAO_0000115>A resin matrix ceramic dental restoration material that contains zirconia or silica based ceramic filler, typically to improve esthetics, strength, and wear resistance.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:47:07Z</dcterms:created>
        <rdfs:label xml:lang="en">resin matrix zirconia silica ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001051 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001051">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001032"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_140503"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_48733"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/ENVO_01000481"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A glass matrix ceramic dental restoration material that primarily contains a ternary material system composed of kaolin (hydrated aluminosilicate), silica, and naturally occurring feldspar (a mixture of potassium and sodium aluminosilicates).</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:47:42Z</dcterms:created>
        <rdfs:label xml:lang="en">feldspathic glass matrix ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001052 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001052">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001032"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30187"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_30563"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/CHEBI_88321"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A glass matrix ceramic dental restoration material that contains synthetic materials which varies among manufacturers, but commonly includes silicon dioxide (SiO2), potassium oxide (K2O), sodium oxide (Na2O), and aluminum oxide (Al2O3).</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:47:59Z</dcterms:created>
        <rdfs:label xml:lang="en">synthetic glass matrix ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001053 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001053">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001052"/>
        <obo:IAO_0000115>A synthetic glass matrix ceramic that contains a leucite (K2OAl2O34SiO2) crystalline phase dispersed in a glass matrix.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:48:16Z</dcterms:created>
        <rdfs:label xml:lang="en">leucite based synthetic glass matrix ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001054 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001054">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001052"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0001081"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A synthetic glass matrix ceramic that contains a lithium disilicate system (SiO2-Li2O-K2O-ZnO-P2O5 Al2O3-[zirconium dioxide] ZrO2).</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:48:33Z</dcterms:created>
        <rdfs:label xml:lang="en">lithia based synthetic glass matrix ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0001055 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001055">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0001052"/>
        <obo:IAO_0000115>A synthetic glass matrix ceramic in which the glass phases may be combined with apatite crystals, in addition to leucite, for thermal expansion compatibility with metals and for improved strength.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2024-08-30T13:48:47Z</dcterms:created>
        <rdfs:label xml:lang="en">fluorapatite based synthetic glass matrix ceramic dental restoration material</rdfs:label>
    </owl:Class>
    


