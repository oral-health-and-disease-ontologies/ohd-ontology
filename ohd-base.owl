            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>An inlay restoration procedure that uses metal to restore the tooth.</obo:IAO_0000115>
        <obo:IAO_0000118>metallic inlay restoration</obo:IAO_0000118>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
