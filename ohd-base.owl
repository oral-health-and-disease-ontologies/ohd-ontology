    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000223">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000208"/>
        <obo:IAO_0000115>A restored tooth surface that forms the distal surface of a restored tooth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:41:41Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">restored distal surface</rdfs:label>
    </owl:Class>
    


