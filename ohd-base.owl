        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000208"/>
        <obo:IAO_0000115>A restored tooth surface that forms the incisal surface of a restored tooth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:44:18Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">restored incisal surface</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000225 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000225">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000235"/>
        <obo:IAO_0000115>A restored tooth surface that forms the labial surface of a restored tooth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:47:52Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">restored labial surface</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000226 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000226">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000208"/>
        <obo:IAO_0000115>A restored tooth surface that forms the lingual surface of a restored tooth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:49:31Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">restored lingual surface</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000227 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000227">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000208"/>
        <obo:IAO_0000115>A restored tooth surface that forms the mesial surface of a restored tooth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:50:33Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">restored mesial surface</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000228 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000228">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000208"/>
        <obo:IAO_0000115>A restored tooth surface that forms the occlusal surface of a restored tooth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:51:08Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">restored occlusal surface</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000229 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000229">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000243"/>
        <obo:IAO_0000115>A surgical endodontic procedure involving a multi-root tooth in which the decayed root and its related coronal portion are removed to the furcation (area of bone loss).</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/29/2016:
Typically the removal of root/crown/bone is followed by the placement of an indirect restoration.</obo:IAO_0000116>
        <obo:IAO_0000119>http://medical-dictionary.thefreedictionary.com/hemisection</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:30:43Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">hemisection procedure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000230 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000230">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000242"/>
        <obo:IAO_0000115>A restored tooth in which the tooth&apos;s pulp is removed and replaced by dental restoration material.</obo:IAO_0000115>
        <obo:IAO_0000118>root canal treatment procedure</obo:IAO_0000118>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:21:35Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">endodontic treatment procedure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000231 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000231">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UBERON_0001091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000044"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000312"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000044"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000112>A tooth in which inflamed pulp has been removed by a pulp debridement procedure.</obo:IAO_0000112>
        <obo:IAO_0000115>A tooth that has been modified in some way as the result of some surgical dental procedure.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/29/2016:
The intent of this class is to represent teeth that have undergone some kind of surgical procedure, but which are not restored in the sense of having dental restoration material placed in them; e.g, a pulp debridement procedure.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:12:10Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">surgically modified tooth</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000232 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000232">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000243"/>
        <obo:IAO_0000115>A surgical endodontic procedure in which infected pulp is removed from a tooth in order to give the remaining pulp room to swell.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/29/2016:
This procedure relieves some of the pain, allowing a root canal patient to wait longer before having the full procedure performed.</obo:IAO_0000116>
        <obo:IAO_0000119>http://www.ehow.com/facts_7478434_pulpal-debridement.html</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:32:55Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">pulpal debridement procedure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000233 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000233">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/UBERON_0001091"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000295"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000057"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001091"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000295"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000057"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A tooth that has been surgically extracted from a patient&apos;s mouth.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/29/2016:
This class represents those teeth which are extracted from a patient. After all, an extracted tooth is still a tooth. It just isn&apos;t part of the patient anymore.

This class provides us with a convient way to represent those teeth that have been extracted.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:15:20Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">extracted tooth</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000235 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000235">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OHD_0000208"/>
                    <owl:Class>
                        <owl:unionOf rdf:parseType="Collection">
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OHD_0000222"/>
                            <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OHD_0000225"/>
                        </owl:unionOf>
                    </owl:Class>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000208"/>
        <obo:IAO_0000115>A restored tooth surface that forms the lip-facing or cheek-facing surface of a restored tooth.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 01/05/2017:
Some dental EHR systems use the letter &quot;F&quot; for facial surfaces rather than &quot;L&quot; for labial surfaces. The reason is that &quot;L&quot; is also used for the lingual surface.</obo:IAO_0000116>
        <obo:IAO_0000116>Gopikrishnan M. Chandrasekharan 07/12/2023:
We decided that the facial surface should subsume both labial and buccal surfaces.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0006-7251-3026"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:42:40Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">restored facial surface</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000236 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000236">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OHD_0000189"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000295"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000242"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000189"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000295"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000242"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A restored tooth in which some portion of the tooth&apos;s root or pulp has been replaced by dental restoration material as a result of the tooth undergoing an endodontic restorative procedure.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:00:27Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">endodontically restored tooth</rdfs:label>
    </owl:Class>
    


