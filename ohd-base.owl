        </rdfs:subClassOf>
        <obo:IAO_0000115>a dental health care provider that bears a dental hygienist role</obo:IAO_0000115>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <rdfs:label>dental hygienist</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000021 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000021">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000260"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000442"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002354"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000442"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A tooth disorder that affects a tooth that includes both the infectious organisms, the material they generate from the tooth, any immune effectors that are a response to the presence of the disorder and the physical changes to the tooth (i.e., demineralization or a cavity) resulting from the disorder. It is the physical basis for the disease &quot;dental caries.&quot;</obo:IAO_0000115>
        <obo:IAO_0000116>Titus Schleyer 1/14/2014: updated definition</obo:IAO_0000116>
        <obo:IAO_0000117>Titus Schleyer</obo:IAO_0000117>
        <rdfs:comment>is caries a material entity or a quality?
</rdfs:comment>
        <rdfs:label xml:lang="en">carious tooth lesion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000022 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000022">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OHD_0000133"/>
