    <!-- http://purl.obolibrary.org/obo/OHD_0000014 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OHD_0000014">
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/OHD_0000012"/>
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <obo:IAO_0000115>a data property that relates an individual patient to the literal string that represents the patient&apos;s id</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <rdfs:label xml:lang="en">patient ID</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000015 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OHD_0000015">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#dateTime"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <obo:IAO_0000115>a data property that relates either:
1. a finding to the date on which it was recorded
2. a process to the date on which it occrred</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 5/23/2012:
There is a problem with occurrence date.  The date on which an event occurred and the date on which it the event was recorded do not always match up.  This will eventually need to be fixed.</obo:IAO_0000116>
        <rdfs:label xml:lang="en">occurrence date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000050 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OHD_0000050">
        <rdfs:subPropertyOf rdf:resource="http://www.w3.org/2002/07/owl#topDataProperty"/>
        <rdfs:domain rdf:resource="http://purl.obolibrary.org/obo/OHD_0000012"/>
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#dateTime"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <obo:IAO_0000115>a data property that relates an individual to the date on which the individual was born</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <rdfs:label xml:lang="en">birth date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000097 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OHD_0000097">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <obo:IAO_0000115>a data property in which the values provide information as to whether a patient is actively being cared for by the practicet; takes values &quot;active&quot; and &quot;inactive&quot;</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T01:11:57Z</oboInOwl:creation_date>
        <rdfs:label>has patient activity status</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000218 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OHD_0000218">
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#dateTime"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <obo:IAO_0000115>a data property used to record the date of a patient&apos;s first dental visit</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T01:22:17Z</oboInOwl:creation_date>
        <rdfs:label>first dental visit date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000219 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OHD_0000219">
        <rdfs:range>
            <rdfs:Datatype>
                <owl:unionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#date"/>
                    <rdf:Description rdf:about="http://www.w3.org/2001/XMLSchema#dateTime"/>
                </owl:unionOf>
            </rdfs:Datatype>
        </rdfs:range>
        <obo:IAO_0000115>a data property used to record the last date on which a patient had a dental visit</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T01:23:31Z</oboInOwl:creation_date>
        <rdfs:label>last dental visit date</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000234 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OHD_0000234">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <obo:IAO_0000115>a data property whose value is an ADA universal tooth number that represents a tooth which is missing from a dentition</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 01/03/2017:
This data property provides a means to query for missing teeth. Since a missing tooth is not a tooth, it is wrong represent a missing tooth as an instance of a tooth. Rather, we represent a missing tooth by respresenting the instance of the dentition and then specify with this data property that the dentition is missing a tooth designated by the universtal tooth number.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:created>2017-01-03T18:37:35Z</dcterms:created>
        <rdfs:label xml:lang="en">missing tooth number</rdfs:label>
    </owl:DatatypeProperty>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000360 -->

    <owl:DatatypeProperty rdf:about="http://purl.obolibrary.org/obo/OHD_0000360">
        <rdfs:range rdf:resource="http://www.w3.org/2001/XMLSchema#string"/>
        <obo:IAO_0000115>a data property whose value is an ADA universal tooth number that represents the tooth associated with a tooth root that is missing from a dentition</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 10/18/2017:
This data property provides a means to query for missing tooth roots. Since a missing tooth root is not a tooth root, it is wrong represent a missing tooth root as an instance of a tooth root. Rather, we represent a missing tooth root by respresenting the instance of the dentition and then specify with this data property that the dentition is missing a tooth root that is associated with the tooth designated by the universtal tooth number.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:created>2017-10-18T20:39:14Z</dcterms:created>
        <rdfs:label xml:lang="en">missing tooth root number</rdfs:label>
    </owl:DatatypeProperty>
    


