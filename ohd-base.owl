    <!-- http://purl.obolibrary.org/obo/OHD_0008017 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0008017">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0008008"/>
        <obo:IAO_0000115 xml:lang="en">A dental assessment instrument developed by Armfield (2010) to measure the four components of anxiety (emotional, behavioural, physiological, cognitive), which provides a screening measure for the psychiatric anxiety diagnosis of specific phobia of dentistry, and which comprises common dental anxiety triggers relevant to both clinicians and research.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-10T13:28:37Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0005009"/>
        <rdfs:label xml:lang="en">Index of Dental Anxiety and Fear (IDAF-4C+)</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0008017"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A dental assessment instrument developed by Armfield (2010) to measure the four components of anxiety (emotional, behavioural, physiological, cognitive), which provides a screening measure for the psychiatric anxiety diagnosis of specific phobia of dentistry, and which comprises common dental anxiety triggers relevant to both clinicians and research.</owl:annotatedTarget>
        <obo:IAO_0000119>https://onlinelibrary.wiley.com/doi/10.1111/eos.12731</obo:IAO_0000119>
        <obo:IAO_0000119>https://psycnet.apa.org/buy/2010-10892-008</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0008018 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0008018">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0008008"/>
        <obo:IAO_0000115 xml:lang="en">A dental fear and anxiety assessment instrument initially described by Kleinknecht et al. (1973) used to identify specific fear stimuli such as seeing the needle and smelling the smell of the dental office, as well as to measure patients’ reactions concerning the avoidance of dentistry and  physiological arousal during a dental appointment.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-10T13:28:59Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0005009"/>
        <rdfs:label xml:lang="en">Dental Fear Survey (DFS)</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0008018"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A dental fear and anxiety assessment instrument initially described by Kleinknecht et al. (1973) used to identify specific fear stimuli such as seeing the needle and smelling the smell of the dental office, as well as to measure patients’ reactions concerning the avoidance of dentistry and  physiological arousal during a dental appointment.</owl:annotatedTarget>
        <obo:IAO_0000119>https://pmc.ncbi.nlm.nih.gov/articles/PMC4144391/</obo:IAO_0000119>
        <obo:IAO_0000119>https://www.sciencedirect.com/science/article/abs/pii/S0002817773640275</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0008019 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0008019">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0008008"/>
        <obo:IAO_0000115 xml:lang="en">A dental fear and anxiety assessment instrument initially described by Corah (1969) which measures the degree of anxiety related to dental treatment via a four item multiple choice questionnaire.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-03-10T13:30:01Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0005009"/>
        <rdfs:label xml:lang="en">Dental Anxiety Scale (DAS)</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0008019"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A dental fear and anxiety assessment instrument initially described by Corah (1969) which measures the degree of anxiety related to dental treatment via a four item multiple choice questionnaire.</owl:annotatedTarget>
        <obo:IAO_0000119>https://journals.sagepub.com/doi/abs/10.1177/00220345690480041801</obo:IAO_0000119>
        <obo:IAO_0000119>https://peerj.com/articles/2978.pdf</obo:IAO_0000119>
    </owl:Axiom>
    


