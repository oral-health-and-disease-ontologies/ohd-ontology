        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 2.1.2.3.1</rdfs:comment>
        <rdfs:label xml:lang="en">chronic highly frequent primary myofascial orofacial pain without pain referral</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010229 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010229">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010226"/>
        <obo:IAO_0000115>Chronic highly frequent pain that is localized to the affected area.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:35:37Z</dcterms:created>
        <rdfs:label xml:lang="en">chronic highly frequent pain without pain referral</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010230 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010230">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010226"/>
        <obo:IAO_0000115>Chronic highly frequent pain with pain referral that occurs beyond the affected area.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:37:56Z</dcterms:created>
        <rdfs:label xml:lang="en">chronic highly frequent pain with pain referral</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010231 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010231">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010227"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010230"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Chronic highly frequent primary myofascial orofascial pain with a report of pain at a site beyond the boundary of the muscle being palpated.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:39:54Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 2.1.2.3.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic highly frequent primary myofascial orofacial pain with pain referral</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010232 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010232">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010003"/>
        <obo:IAO_0000115>Myofascial pain caused by an underlying disorder (inflammation, infection or muscle spasm).</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:44:16Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 2.2</rdfs:comment>
        <rdfs:label xml:lang="en">secondary myofascial orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010233 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010233">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010232"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010291"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Pain of tendon origin, affected by jaw movement, function or parafunction and replicated by provocation-testing of the relevant masticatory tendon. Limitation of mandibular movement(s) secondary to pain may be present. The temporalis tendon is a common site of tendonitis and may refer pain to the teeth and other nearby structures. Tendonitis can also occur in other masticatory muscle tendons.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:46:19Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 2.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">myofascial orofacial pain attributed to tendonitis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010234 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010234">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010232"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010305"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Pain caused by myositis affecting one or more masticatory muscles, with clinical characteristics of inﬂammation or infection: oedema, erythema and/or increased temperature. It generally arises acutely following direct trauma of the muscle or from infection, or chronically with autoimmune disease. Limitation of unassisted mandibular movements secondary to pain is often present. Calciﬁcation of the muscle can occur (i.e. myositis ossiﬁcans).</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:48:14Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 2.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">myofascial orofacial pain attributed to myositis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010235 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010235">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010232"/>
        <obo:IAO_0000115>Pain caused by sudden, involuntary, reversible tonic contraction of a muscle. Such spasm may affect any of the masticatory muscles. Acute malocclusion may be present.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:49:34Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 2.2.3</rdfs:comment>
        <rdfs:label xml:lang="en">myofascial orofacial pain attributed to muscle spasm</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010236 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010236">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010128"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010306"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>TMJ pain caused by persistent inflammation of articular tissues (due, for example, to trauma, infection, crystal deposition or autoimmune disorder). TMJ pain is common in TMJ arthritis, but TMJ arthritis can be present without pain.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:52:37Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to arthritis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010237 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010237">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010236"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010307"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Temporomandibular joint pain due to arthritis with evidence of systemic inflammatory joint disease but not evidence that associates it with the TMJ pain or no evidence of rheumatological disease.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:53:36Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to non-systemic arthritis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010238 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010238">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010236"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010308"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Temporomandibular joint due to arthritis with evidence of systemic inflammatory joint disease, pain developed in close temporal relation to other symptoms, and either the pain has significantly worsened in parallel with worsening of the systemic inflammatory joint disease or the pain has significantly improved or resolved with treatment of the systemic inflammatory joint disease.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:54:43Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to systemic arthritis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010239 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010239">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010128"/>
        <obo:IAO_0000115>TMJ pain caused by TMJ disc displacement in the absence of TMJ arthritis. TMJ pain can here be due to mechanical derangements within the joint.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T17:58:05Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to disc displacement</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010240 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010240">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010239"/>
        <obo:IAO_0000115>Secondary temporomandibular joint pain due to TMJ disc displacement with reduction that any TMJ noise on jaw movement or function have been reported and clicking, popping, or snapping noises detected with palpation on the jaw opening and closing.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:01:04Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to disc displacement with reduction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010241 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010241">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010240"/>
        <obo:IAO_0000115>Temporomandibular joint pain due to disc displacement with reduction with intermittent jaw locking with limited mouth opening.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:02:56Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.2.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to disc displacement with reduction, with intermittent locking</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010242 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010242">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010239"/>
        <obo:IAO_0000115>Secondary temporomandibulare join pain due to TMJ disc displacement without reduction, which has been diagnosed by jaw locking or limitation of jaw opening. Along with evidence of pain developing in close temporal relation to the disc dsiplacement, a significant worsening in pain paralelle.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:04:14Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain attributed to disc displacement without reduction</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010243 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010243">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010128"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010309"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>TMJ pain caused by degenerative joint disorder (osteoarthrosis, osteoarthritis) in the absence of TMJ arthritis.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:06:11Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.3</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain due to degenerative joint disease</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010244 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010244">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010128"/>
        <obo:IAO_0000115>TMJ pain caused by subluxation, in the absence of TMJ arthritis. It is usually acute, and probably due to overstretching of tissues.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:06:56Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 3.2.4</rdfs:comment>
        <rdfs:label xml:lang="en">temporomandibular joint pain due to subluxation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010245 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010245">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010129"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010251"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Trigeminal neuralgia with neither electrophysiological tests nor MRI showing significant abnormalities.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-01T18:12:38Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP term: 4.1.1.3</rdfs:comment>
        <rdfs:label xml:lang="en">idiopathic trigeminal neuralgia</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010246 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010246">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010131"/>
        <obo:IAO_0000115>Trigeminal neuralgia caused by a multiple sclerosis (MS) plaque or plaques in the pons or trigeminal root entry zone, and associated with other symptoms and/or clinical or laboratory findings of MS.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:04:21Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.1.1.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">trigeminal neuralgia due to multiple sclerosis</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010247 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010247">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010131"/>
        <obo:IAO_0000115>Trigeminal neuralgia caused by contact between the affected trigeminal nerve and a space-occupying lesion.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:07:10Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.1.1.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">trigeminal neuralgia due to space-occupying lesion</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010248 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010248">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000085"/>
        <obo:IAO_0000115>Pain that is persistently occuring in the background.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:13:19Z</dcterms:created>
        <rdfs:label xml:lang="en">concomitant continuous pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010249 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010249">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010130"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010248"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Classical trigeminal neuralgia with persistent background pain.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:15:13Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.1.1.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">classical trigeminal neuralgia with concomitant continuous pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010250 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010250">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010245"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010248"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Idiopathic trigeminal neuralgia with recurrent paroxysms of unilateral facial pain that is concomitant continuous of near-continuous pain between attacks in the affected trigeminal distirbution.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:16:21Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.1.1.3.2</rdfs:comment>
        <rdfs:label xml:lang="en">idiopathic trigeminal neuralgia with concomitant continuous pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010251 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010251">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000085"/>
        <obo:IAO_0000115>Pain with no identifiable cause.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:20:02Z</dcterms:created>
        <rdfs:label xml:lang="en">idiopathic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010252 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010252">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000085"/>
        <obo:IAO_0000115>Pain cause by damage to nerve fibers.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:21:25Z</dcterms:created>
        <rdfs:label xml:lang="en">neuropathic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010253 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010253">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010132"/>
        <obo:IAO_0000115>Glossopharyngeal nerve associated pain that occurs within the distribution of the glossopharyngeal nerve (posterior part of the tongue, tonsillar fossa, pharynx or beneath the angle of the lower jaw). In addition, pain is commonly perceived in the ipsilateral ear. The primary pain is usually continuous or near-continuous, and commonly described as burning or squeezing, or likened to pins and needles. Brief paroxysms may be superimposed but they are not the predominant pain type. This combination distinguishes 4.2.2 Glossopharyngeal neuropathic pain from 4.2.1 Glossopharyngeal neuralgia. Sensory deficits may be present in the ipsilateral posterior part of the tongue and tonsillar fossa, and the gag reflex may be weak or missing.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:24:40Z</dcterms:created>
        <oboInOwl:hasRelatedSynonym>glossopharyngeal neuropathic pain due to a known cause</oboInOwl:hasRelatedSynonym>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.2.2</rdfs:comment>
        <rdfs:comment>realted ICOP number: 4.2.2.1</rdfs:comment>
        <rdfs:label xml:lang="en">glossopharyngeal neuropathic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010254 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010254">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010253"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010251"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Unilateral continuous or near-continuous pain, with or without superimposed brief paroxysms, in the distribution(s) of the glossopharyngeal nerve and of unknown aetiology.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:28:43Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.2.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">idiopathic glossopharyngeal neuropathic pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010255 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010255">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010000"/>
        <obo:IAO_0000115>Orofacial pains resembling presentations of primary headaches.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:31:48Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5</rdfs:comment>
        <rdfs:label xml:lang="en">orofacial pain with headache presentation</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010256 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010256">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010255"/>
        <obo:IAO_0000115>Episodic or chronic pain exclusively in the orofacial region, without head pain, with the characteristics and associated features of 1. Migraine described in ICHD-3.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:32:24Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.1</rdfs:comment>
        <rdfs:label xml:lang="en">orofacial migraine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010257 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010257">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010256"/>
        <obo:IAO_0000115>Recurrent orofacial pain (OFP) attacks, without head pain, lasting 4–72 hours. Typical characteristics of the pain are unilateral location, pulsating quality, moderate or severe intensity, aggravation by routine physical activity and association with nausea and/or photophobia and phonophobia.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:33:53Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">episodic orofacial migraine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010258 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010258">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010256"/>
        <obo:IAO_0000115>Facial or oral pain occurring on 15 or more days per month for more than 3 months, which has the features of migraine on at least 8 days per month.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:34:44Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic orofacial migraine</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010259 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010259">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010255"/>
        <obo:IAO_0000115>Episodic or chronic pain exclusively in the orofacial region, without head pain, with the characteristics and associated features of 2. Tension-type headache described in the International Classification of Headache Disorders 3rd Edition, which can include pressing or tightening with mild to moderate intensity with bilateral location.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:36:31Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.2</rdfs:comment>
        <rdfs:label xml:lang="en">tension-type orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010260 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010260">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010255"/>
        <obo:IAO_0000115>Attacks of pain, exclusively in the orofacial region, without head pain, with the characteristics and associated features of a disorder described under 3. Trigeminal autonomic cephalalgias in the International Classification of Headache Disorders 3rd Edition, which include conjunctival injection and/or lacrimation, nasal congestion and/or rhinorrhoea, eyelid oedema, forehead and facial sweating, miosis and/or ptosis.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-02T19:37:03Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3</rdfs:comment>
        <rdfs:label xml:lang="en">trigeminal autonomic orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010261 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010261">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010260"/>
        <obo:IAO_0000115>Attacks of severe, strictly unilateral facial and/or oral pain, without head pain, lasting 15–180 minutes and occurring from once every other day to eight times a day. The pain is associated with ipsilateral conjunctival injection, lacrimation, nasal congestion, rhinorrhoea, forehead and facial sweating, miosis, ptosis and/or eyelid oedema, and/or with restlessness or agitation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:16:21Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.1</rdfs:comment>
        <rdfs:label xml:lang="en">orofacial cluster attacks</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010262 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010262">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010261"/>
        <obo:IAO_0000115>Orofacial cluster attacks occurring in periods lasting from 7 days to 1 year, separated by pain-free periods lasting at least 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:16:59Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">episodic orofacial cluster attacks</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010263 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010263">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010261"/>
        <obo:IAO_0000115>Orofacial cluster attacks occurring for more than 1 year without remission, or with remission periods lasting less than 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:17:49Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic orofacial cluster attacks</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010264 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010264">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010260"/>
        <obo:IAO_0000115>Attacks of severe, strictly hemifacial pain, without head pain, lasting 2–30 minutes and occurring several or many times a day. The attacks may be associated with ipsilateral conjunctival injection, lacrimation, nasal congestion, rhinorrhoea, forehead and facial sweating, miosis, ptosis and/or eyelid oedema.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:18:22Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.2</rdfs:comment>
        <rdfs:label xml:lang="en">paroxysmal hemifacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010265 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010265">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010264"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
