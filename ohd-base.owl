        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0002000"/>
        <obo:IAO_0000115>A masticatory muscle activity that may result in a disorder within the head and neck region.</obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Involuntary holding of the teeth together and tightening of the jaw muscles or grinding of the teeth.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0006-7251-3026"/>
        <dcterms:created>2023-06-06T21:27:37Z</dcterms:created>
        <rdfs:label xml:lang="en">bruxism</rdfs:label>
    </owl:Class>
    


