            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010183"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Periodontal pain due to periodontal disease resulting from either or both of the following: acute inflammation and loss of attatchement, or marginal and periradicular bone resorption.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
