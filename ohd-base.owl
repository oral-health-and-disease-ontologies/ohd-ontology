            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Orofacial pain attributed to lesion or disease of the glossopharyngeal nerve.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
