                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000000"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A tooth that has been restored by using dental restoration material to replace decayed or missing parts of the tooth.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/29/2017:
A restored tooth typically results when a tooth with some type of pathological defect is restored.</obo:IAO_0000116>
        <obo:IAO_0000116>Titus Schleyer 1/1/2014: updated definition</obo:IAO_0000116>
        <obo:IAO_0000117>Alan Ruttenberg</obo:IAO_0000117>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
