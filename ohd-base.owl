                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000010"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A conversational, visual and tactile examination in which the clinician evaluates the status of the patient&apos;s medical, dental and oral health. </obo:IAO_0000115>
        <obo:IAO_0000116 xml:lang="en">Melissa Haendel 4/12/2012: There can be more than one dental exam that occurs during a dental visit.</obo:IAO_0000116>
        <obo:IAO_0000116>Titus Schleyer 1/1/2014: original definition was too narrow, now expanded</obo:IAO_0000116>
        <obo:IAO_0000117 xml:lang="en">Mellisa Haendel</obo:IAO_0000117>
        <obo:IAO_0000117 xml:lang="en">Person:Alan Ruttenberg</obo:IAO_0000117>
        <rdfs:label xml:lang="en">dental exam</rdfs:label>
    </owl:Class>
    


