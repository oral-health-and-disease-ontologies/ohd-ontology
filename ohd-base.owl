    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000031 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000031">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/IDO_0000436"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000054"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000443"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0004020"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000420"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">An infectious disease realized in a disease course during which a carious lesion develops in a tooth, resulting in demineralization, loss of tooth structure/appearance of a cavity or other structural damage to the tooth.</obo:IAO_0000115>
        <obo:IAO_0000116> Titus Schleyer 3/4/2014: definition updated</obo:IAO_0000116>
        <obo:IAO_0000116 xml:lang="en">Alan Ruttenberg 4/12/2012: We need to hook up the disease with the material basis, and possible a representation of the disease course. However we don&apos;t have the &apos;has material basis&apos; relation yet, and its not clear that it is useful to represent the disease course.</obo:IAO_0000116>
        <obo:IAO_0000116>Bill Duncan 6/26/2015:
The old uri was DOID_216. I assume this class is intended to be an import from the disease ontology.
The uri was changed for backward compatabilty in the r21 study.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0002-1604-3078"/>
        <rdfs:label xml:lang="en">dental caries</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000032 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000032">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000019"/>
        <obo:IAO_0000115>a dental exam which focuses on soft tissue in and near the mouth.</obo:IAO_0000115>
        <obo:IAO_0000117>Alan Ruttenberg</obo:IAO_0000117>
        <rdfs:label xml:lang="en">soft tissue exam</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000033 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000033">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000004"/>
        <obo:IAO_0000115>A tooth restoration procedure whereby an artificial crown replaces all or part of the natural dental crown.</obo:IAO_0000115>
        <obo:IAO_0000116>Titus Schleyer 1/14/2014: adapted definition</obo:IAO_0000116>
        <rdfs:label xml:lang="en">crown restoration procedure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000034 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000034">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000048"/>
        <obo:IAO_0000115>A metal dental restoration material in which the principal ingredient is gold.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/11/2014:
updated defintion</obo:IAO_0000116>
        <obo:IAO_0000116>Titus Schleyer 3/13/2014: slightly updated definition</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-1829-971X"/>
        <rdfs:label>gold foil dental restoration material</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000035 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000035">
        <rdfs:subClassOf rdf:resource="http://www.geneontology.org/formats/oboInOwl#ObsoleteClass"/>
        <obo:IAO_0100001 rdf:resource="http://purl.obolibrary.org/obo/OHD_0000135"/>
        <rdfs:label>obsolete porcelain dental restoration material</rdfs:label>
        <owl:deprecated rdf:datatype="http://www.w3.org/2001/XMLSchema#boolean">true</owl:deprecated>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000036 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000036">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000000"/>
        <obo:IAO_0000115>A dental restoration material that is primarily composed of highly cross-linked organic polymeric matrix reinforced by filler particles and/or short fibers bound to the matrix by coupling agents and set by light and or chemically activated polymerization reaction.</obo:IAO_0000115>
        <obo:IAO_0000116>Titus Schleyer 3/13/2014: updated definition

Bill D. 08-04-2023: Not all resins are tooth colored. Some are cream colored. Also, updated definition source Craig&apos;s restorative Dental Material.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-1829-971X"/>
        <rdfs:label>resin-based composite dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0000036"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A dental restoration material that is primarily composed of highly cross-linked organic polymeric matrix reinforced by filler particles and/or short fibers bound to the matrix by coupling agents and set by light and or chemically activated polymerization reaction.</owl:annotatedTarget>
        <obo:IAO_0000119>Craig&apos;s restorative Dental Material</obo:IAO_0000119>
        <obo:IAO_0000119>ISBN:0323478212</obo:IAO_0000119>
    </owl:Axiom>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000037 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000037">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000652"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001091"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A material combination in which a moldable restorative material is placed directly into or on the tooth. The material then hardens and becomes (essentially) part of the tooth. </obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/11/2014:
Moved from this class from being a subtype of tooth restoration procedure to being a subclass of material combination.</obo:IAO_0000116>
        <obo:IAO_0000116>Titus Schleyer 1/1/2014: made definition clearer</obo:IAO_0000116>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <rdfs:label xml:lang="en">direct dental material insertion process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000038 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000038">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OBI_0000652"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/UBERON_0001091"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A material combination in which a rigid piece of restoration material is attached to a tooth. The restoration is attached to the tooth by mechanical forces or some form of cement or glue. </obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/11/2014:
Moved from this class from being a subtype of tooth restoration procedure to being a subclass of material combination.</obo:IAO_0000116>
        <obo:IAO_0000116>Bill Duncan 12/16/2014:
Updated definition.

Original definition:
A material combination in which a rigid restoration, such as a gold inlay, is attached to a tooth. The restoration is attached to the tooth by some form of cement or glue. 

1. Removed &quot;such as a gold inlay&quot;.

2. Added that the material may be held in place by mechanical forces</obo:IAO_0000116>
        <obo:IAO_0000116>Titus Schleyer 1/14/2014: made the definition consistent with that of direct restoration</obo:IAO_0000116>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <rdfs:label xml:lang="en">dental material tooth attachment process</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000039 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000039">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OHD_0000006"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000051"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000038"/>
                    </owl:Restriction>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000293"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000034"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000006"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000304"/>
        <rdfs:subClassOf>
