            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A dental finding that one or more surfaces of a tooth have been restored.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T01:39:35Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">restored tooth surface finding</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000221 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000221">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000010"/>
        <obo:IAO_0000115>A dental finding that a dental procedure has been performed on a patient&apos;s mouth.</obo:IAO_0000115>
        <obo:IAO_0000116>Bill Duncan 12/27/2016:

This finding can indicate that a procedure was performed even when the output is not observable. For example, by looking a dental record, a provider may find that the last time a patient&apos;s teeth were cleaned was two years ago.</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2016-12-27T01:45:45Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">dental procedure finding</rdfs:label>
    </owl:Class>
    


