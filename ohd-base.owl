    <!-- http://purl.obolibrary.org/obo/OHD_0000001 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000001">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000048"/>
        <obo:IAO_0000115>A metal dental restoration material that consists of alloy that is formed by reacting mercury with silver, copper, tin and sometimes palladium, zinc and other elements to improve handling characteristics and clinical performance.</obo:IAO_0000115>
        <obo:IAO_0000116>Titus Schleyer 1/14/2014: updated definition</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0003-1829-971X"/>
        <rdfs:comment>Color depends on which metal is in the alloy at what % (e.g. if copper is more, amalgam become blackish).</rdfs:comment>
        <rdfs:label>amalgam dental restoration material</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0000001"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A metal dental restoration material that consists of alloy that is formed by reacting mercury with silver, copper, tin and sometimes palladium, zinc and other elements to improve handling characteristics and clinical performance.</owl:annotatedTarget>
        <obo:IAO_0000119>ISBN: 978-1-4377-2418-9</obo:IAO_0000119>
    </owl:Axiom>
    


