    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000245 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000245">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000002"/>
