    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010179 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010179">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010178"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000047"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Periodontal pain due to periodontitis as a manifestion of a systematic genetic disorder. Genetic disorders which can result in periodontitis include familial and cyclic neutropenia, Down syndrome, leukocyte adhesion deficiency syndromes, Papillon–Lefèvre syndrome, Chediak–Higashi syndrome, histiocytosis syndromes, glycogen storage disease, infantile genetic agranulocytosis, Cohen syndrome, Ehler–Danlos syndrome (types IV and VIII), and hypophosphatasia.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-26T18:54:59Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 1.1.2.1.3.3.2</rdfs:comment>
        <rdfs:label xml:lang="en">periodontal pain due to genetic disorder</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010180 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010180">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010187"/>
        <obo:IAO_0000115>A hematological disorder caused by an infectious disorder.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-26T18:58:07Z</dcterms:created>
        <rdfs:comment>The disorder might arise from an infection, but is not necessarily an infection.</rdfs:comment>
        <rdfs:label xml:lang="en">hematological disorder due to infectious disorder</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010181 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010181">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010178"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010180"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Periodontal pain due to periodontitis as a manifestation of a systematic haematological disorder. Haematological disorders which can result in periodontitis include acquired neutropenia and leukaemia.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-26T18:59:27Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 1.1.2.1.3.3.1</rdfs:comment>
        <rdfs:label xml:lang="en">periodontal pain due to haematological disorder</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010182 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010182">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010102"/>
