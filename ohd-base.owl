        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000242"/>
        <obo:IAO_0000115>An endodontic restorative procedure during which material is placed over exposed or nearly dental pulp in order to protect and promote healing of the dental pulp.</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Pulp_capping</obo:IAO_0000119>
