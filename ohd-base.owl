        <rdfs:comment>ICOP number: 5.3.2.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic paroxysmal hemifacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010268 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010268">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010260"/>
        <obo:IAO_0000115>Attacks of moderate or severe, strictly unilateral oral and/or facial pain, without head pain, lasting seconds to minutes, occurring at least once a day and usually associated with prominent lacrimation and redness of the ipsilateral eye and/or other local autonomic symptoms and/or signs.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:23:06Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.3</rdfs:comment>
        <rdfs:label xml:lang="en">short-lasting unilateral neuralgiform facial pain attacks with cranial autonomic symptoms (SUNFA)</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010269 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010269">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010268"/>
        <obo:IAO_0000115>Attacks of SUNFA occurring in periods lasting from 7 days to 1 year, separated by pain-free periods lasting at least 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:26:23Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.3.1</rdfs:comment>
        <rdfs:label xml:lang="en">episodic SUNFA</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010270 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010270">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010268"/>
        <obo:IAO_0000115>Attacks of SUNFA occurring for more than 1 year without remission, or with remission periods lasting less than 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:26:56Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.3.2</rdfs:comment>
        <rdfs:label xml:lang="en">chronic SUNFA</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010271 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010271">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010260"/>
        <obo:IAO_0000115>While no isolated facial equivalent of 3.4 Hemicrania continua, described in International Classification of Headache Disorders 3rd Edition,, has so far been clearly established, extension of pain into the face in hemicrania continua has been described. Thus, pain referral and/or radiation to oral and/or facial structures may cause diagnostic difficulties.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:27:44Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.3.4</rdfs:comment>
        <rdfs:label xml:lang="en">hemifacial continuous pain with autonomic symptoms</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010272 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010272">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010255"/>
        <obo:IAO_0000115>Attacks of variable duration of moderate or severe intraoral pain, without head pain, often accompanied by toothache-like symptoms, with mild autonomic and/or migrainous symptoms. Two subforms are represented by patients with relatively short attacks (1–4 hours) and those with longer attacks (&gt;4 hours).</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:28:50Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.4</rdfs:comment>
        <rdfs:label xml:lang="en">neurovascular orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010273 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010273">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010272"/>
        <obo:IAO_0000115>Neurovascular orofacial pain that lasts between 1-4 hours.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:30:01Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.4.1</rdfs:comment>
        <rdfs:label xml:lang="en">short-lasting neurovascular orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010274 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010274">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010272"/>
        <obo:IAO_0000115>Neurovascular orofacial pain that lasts more than 4 hours.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:30:34Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 5.4.2</rdfs:comment>
        <rdfs:label xml:lang="en">long-lasting neurovascular orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010275 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010275">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010000"/>
        <obo:IAO_0000115>Orofacial pain involving unilateral or bilateral intraoral or facial pain in the distribution(s) of one or more branches of the trigeminal nerve(s) for which the aetiology is unknown. The pain is usually persistent, of moderate intensity, poorly localized and described as dull, pressing or of burning character.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:31:21Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6</rdfs:comment>
        <rdfs:label xml:lang="en">idiopathic orofacial pain</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010276 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010276">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010275"/>
        <obo:IAO_0000115>An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day for more than 3 months, without evident causative lesions on clinical examination and investigation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:32:34Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.1</rdfs:comment>
        <rdfs:label xml:lang="en">burning mouth syndrome (BMS)</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010277 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010277">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010276"/>
        <obo:IAO_0000115>An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day for more than 3 months, unaccompanied by somatosensory changes and without evident causative lesions on clinical examination and investigation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:33:11Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">burning mouth syndrome without somatosensory changes</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010278 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010278">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010276"/>
        <obo:IAO_0000115>An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day for more than 3 months and accompanied by negative and/or positive somatosensory changes, without evident causative lesion(s) on clinical examination and investigation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:34:39Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.1.2</rdfs:comment>
        <rdfs:label xml:lang="en">burning mouth syndrome with somatosensory changes</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010279 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010279">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010276"/>
        <obo:IAO_0000115>An intraoral burning or dysaesthetic sensation, recurring daily for more than 2 hours per day but for less than 3 months, without evident causative lesions on clinical examination and investigation.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
