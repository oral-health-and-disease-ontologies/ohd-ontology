                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000010"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </rdfs:subClassOf>
        <obo:IAO_0000115 xml:lang="en">A diagnostic process in which a physician engages in a medical evaluation of teeth, gums, and other structures closely related to mastication.</obo:IAO_0000115>
        <obo:IAO_0000115>should use obi class with modifications to not include restriction that has specified output is a diagnosis, and/or subclass the obi class</obo:IAO_0000115>
        <obo:IAO_0000116>should use obi class with modifications to not include restriction that has specified output is a diagnosis, and/or subclass the obi class</obo:IAO_0000116>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <rdfs:label xml:lang="en">performing a dental clinical assessment</rdfs:label>
    </owl:Class>
    


