        <obo:IAO_0000115>a dental health care provider that bears a dentist role</obo:IAO_0000115>
        <obo:IAO_0000117>Bill Duncan</obo:IAO_0000117>
        <rdfs:label>dentist</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000019 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000019">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000057"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/BFO_0000055"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000052"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <rdfs:subClassOf>
