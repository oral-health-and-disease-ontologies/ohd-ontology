        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-08T17:45:22Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 4.1.2.5</rdfs:comment>
        <rdfs:label xml:lang="en">idiopathic trigeminal neuropathic pain</rdfs:label>
    </owl:Class>
    


