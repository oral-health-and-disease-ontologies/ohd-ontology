    <!-- http://purl.obolibrary.org/obo/OHD_0000444 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000444">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0008008"/>
        <obo:IAO_0000115 xml:lang="en">A dental fear and anxiety assessment instrument initially described by Humphris et al. (1995) that was developed to improve the psychometrics and content validity of the original Dental Anxiety Scale (DAS) by adding an item about receiving dental injections, and ordering the potential answers to each item so that they range from least to greatest level of anxiety.</obo:IAO_0000115>
        <obo:IAO_0000115>A dental fear survey consisting of five questions and summed together to produce a total score ranging from 5 to 25.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0002-7282-0836"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-02-15T19:01:50Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0005009"/>
        <rdfs:label xml:lang="en">Modified Dental Anxiety Scale (MDAS)</rdfs:label>
    </owl:Class>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0000444"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget xml:lang="en">A dental fear and anxiety assessment instrument initially described by Humphris et al. (1995) that was developed to improve the psychometrics and content validity of the original Dental Anxiety Scale (DAS) by adding an item about receiving dental injections, and ordering the potential answers to each item so that they range from least to greatest level of anxiety.</owl:annotatedTarget>
        <obo:IAO_0000119>https://link.springer.com/article/10.1186/1472-6831-9-20</obo:IAO_0000119>
        <obo:IAO_0000119>https://link.springer.com/content/pdf/10.1186/1472-6831-8-29.pdf</obo:IAO_0000119>
    </owl:Axiom>
    <owl:Axiom>
        <owl:annotatedSource rdf:resource="http://purl.obolibrary.org/obo/OHD_0000444"/>
        <owl:annotatedProperty rdf:resource="http://purl.obolibrary.org/obo/IAO_0000115"/>
        <owl:annotatedTarget>A dental fear survey consisting of five questions and summed together to produce a total score ranging from 5 to 25.</owl:annotatedTarget>
        <obo:IAO_0000119>Humphris, G., T. Morrison, and S. J. E. Lindsay. &quot;The Modified Dental Anxiety Scale: UK norms and evidence for validity.&quot; Community Dental Health 12.3 (1995): 143-150.</obo:IAO_0000119>
        <obo:IAO_0000119>https://link.springer.com/article/10.1186/1472-6831-9-20</obo:IAO_0000119>
    </owl:Axiom>
    


