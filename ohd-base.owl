                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000006"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A tooth to be restored role that is realized by an intracoronal restoration procedure</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <rdfs:label>tooth to be filled role</rdfs:label>
