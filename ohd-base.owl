    <!-- http://purl.obolibrary.org/obo/OHD_0010216 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010216">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010215"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002410"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0010140"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>Mild to moderate levels of deep aching or pressing pain in the masticatory muscles, occurring episodically or unremittingly, often associated with functional impairment such as perceived difficulties in moving the lower jaw, chewing and/or yawning, etc., and with onset within the last 3 months.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-30T18:38:53Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 2.1.1</rdfs:comment>
        <rdfs:label xml:lang="en">acute primary myofascial orofacial pain</rdfs:label>
    </owl:Class>
    


