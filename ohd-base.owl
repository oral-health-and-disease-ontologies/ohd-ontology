    <!-- http://purl.obolibrary.org/obo/OHD_0001086 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0001086">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000136"/>
        <obo:IAO_0000115>A titanium dental restoration material that contain pure titanium with 
minimum impurities.</obo:IAO_0000115>
        <obo:IAO_0000118>cp-titanium</obo:IAO_0000118>
        <dcterms:contributor rdf:resource="http://orcid.org/0000-0001-9625-1899"/>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-6424-4096"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-06-20T14:58:36Z</dcterms:created>
        <rdfs:comment>The maximum elemental mass fractions of impurities are: nitrogen 0.012–0.05 mass%, carbon 0.03–0.08 mass%, hydrogen 0.0125 mass%, oxygen 0.1–0.4 mass%, and iron 0.1–0.5 mass% contents.</rdfs:comment>
        <rdfs:label xml:lang="en">commercially pure titanium dental restoration material</rdfs:label>
    </owl:Class>
    


