                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000006"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A coronally restored tooth in which dental restoration material is placed into a site that is located in the crown of the tooth as the result of the tooth undergoing an intracoronal restoration procedure.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T01:57:51Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">intracoronally restored tooth</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000240 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000240">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OHD_0000237"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000295"/>
                        <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000027"/>
                    </owl:Restriction>
                </owl:intersectionOf>
            </owl:Class>
        </owl:equivalentClass>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000237"/>
        <rdfs:subClassOf>
            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000295"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000027"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A coronally restored tooth in which a thin layer of material (i.e., a veneer) has been placed over one or more surfaces of the tooth as a result of the tooth undergoing a veneer restoration procedure.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T01:59:02Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">veneer surface restored tooth</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000241 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000241">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000242"/>
        <obo:IAO_0000115>An endodontic restorative procedure during which a tooth&apos;s root tip is removed and a root end cavity is prepared and filled with dental restoration material.</obo:IAO_0000115>
        <obo:IAO_0000119>https://en.wikipedia.org/wiki/Apicoectomy</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:20:26Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">apicoectomy procedure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000242 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000242">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000003"/>
