            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000116>A processed material that is part of a restored tooth and forms the part of a restored tooth where a the surface enamel of the restored tooth used to be.</obo:IAO_0000116>
        <obo:IAO_0000117>Alan Ruttenberg</obo:IAO_0000117>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <rdfs:label xml:lang="en">restored tooth surface</rdfs:label>
    </owl:Class>
    


