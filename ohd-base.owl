        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OGMS_0000045"/>
        <obo:IAO_0000115>A disorder characterized by the presence of malignant cells.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
