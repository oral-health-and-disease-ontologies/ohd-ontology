    <!-- http://purl.obolibrary.org/obo/OHD_0010288 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010288">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010275"/>
        <obo:IAO_0000115>Constant (unremitting) dull unilateral facial pain of mild to moderate intensity, accompanied by distinct attacks of moderate to severe pain in the same location lasting 10--30 minutes. There are no typical autonomic and/or migrainoid features accompanying either the constant pain or the additional pain attacks.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
        <dcterms:created rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2025-07-07T17:43:15Z</dcterms:created>
        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.4</rdfs:comment>
        <rdfs:label xml:lang="en">constant unilateral facial pain with additional attacks (CUFPA)</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010289 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010289">
        <owl:equivalentClass>
            <owl:Class>
                <owl:intersectionOf rdf:parseType="Collection">
                    <rdf:Description rdf:about="http://purl.obolibrary.org/obo/OGMS_0000045"/>
                    <owl:Restriction>
                        <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/RO_0002353"/>
