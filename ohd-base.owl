            <owl:Restriction>
                <owl:onProperty rdf:resource="http://purl.obolibrary.org/obo/OBI_0000299"/>
                <owl:someValuesFrom rdf:resource="http://purl.obolibrary.org/obo/OHD_0000236"/>
            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A tooth restoration procedure during which some portion of the tooth&apos;s root or pulp is replaced by dental restoration material.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T01:52:43Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">endodontic restorative procedure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000243 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000243">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000003"/>
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000044"/>
        <obo:IAO_0000115>A surgical dental procedure that is performed on the pulp chamber and/or root canal of a tooth, or a part thereof.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:26:59Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">surgical endodontic procedure</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0000244 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0000244">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0000243"/>
        <obo:IAO_0000115>A surgical endodontic procure during which a root is removed from a multi-root tooth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T02:35:48Z</oboInOwl:creation_date>
