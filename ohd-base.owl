            </owl:Restriction>
        </rdfs:subClassOf>
        <obo:IAO_0000115>A removable prosthodontics procedure in which the prosthesis being constructed or fitted replaces some but not all of the patient&apos;s teeth.</obo:IAO_0000115>
        <dcterms:contributor rdf:resource="https://orcid.org/0000-0001-9625-1899"/>
        <oboInOwl:creation_date rdf:datatype="http://www.w3.org/2001/XMLSchema#dateTime">2022-12-06T04:12:21Z</oboInOwl:creation_date>
        <rdfs:label xml:lang="en">removable partial denture procedure</rdfs:label>
    </owl:Class>
    


