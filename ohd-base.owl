        <oboInOwl:inSubset rdf:resource="http://purl.obolibrary.org/obo/OHD_0010296"/>
        <rdfs:comment>ICOP number: 6.1.3</rdfs:comment>
        <rdfs:label xml:lang="en">probable burning mouth syndrome</rdfs:label>
    </owl:Class>
    


    <!-- http://purl.obolibrary.org/obo/OHD_0010280 -->

    <owl:Class rdf:about="http://purl.obolibrary.org/obo/OHD_0010280">
        <rdfs:subClassOf rdf:resource="http://purl.obolibrary.org/obo/OHD_0010275"/>
        <obo:IAO_0000115>Persistent facial pain, with variable features, recurring daily for more than 2 hours per day for more than 3 months, in the absence of clinical neurological deficit or preceding causative event.</obo:IAO_0000115>
        <obo:IAO_0000119>PMID:32103673</obo:IAO_0000119>
        <dcterms:contributor rdf:resource="https://orcid.org/0009-0003-5583-4731"/>
